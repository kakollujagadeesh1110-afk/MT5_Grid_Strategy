}

//+------------------------------------------------------------------+
//| CLOSE ONLY GRID POSITIONS                                        |
//+------------------------------------------------------------------+
void CloseOnlyGridPositions()
{
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      trade.PositionClose(ticket);
   }
}

//+------------------------------------------------------------------+
//| OUTERMOST GRID PRICE                                             |
//+------------------------------------------------------------------+
double GetOuterGridPrice(int type)
{
   bool found = false;

   double price = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      if(PositionGetInteger(POSITION_TYPE)
         != type)
         continue;

      double p =
      PositionGetDouble(POSITION_PRICE_OPEN);

      if(!found)
      {
         found = true;
         price = p;
      }
      else
      {
         if(type == POSITION_TYPE_BUY
            && p < price)
            price = p;

         if(type == POSITION_TYPE_SELL
            && p > price)
            price = p;
      }
   }

   return price;
}

//+------------------------------------------------------------------+
//| V4: GET INCREMENTAL GRID DISTANCE                                |
//| Distance = GridIncrementStep × CurrentGridCount                  |
//+------------------------------------------------------------------+
int GetIncrementalGridDistance()
{
   int gridCount = TotalGridPositions();

   // If no grid yet, first distance is 1 × Step
   if(gridCount == 0)
      gridCount = 1;

   return GridIncrementStep * gridCount;
}

//+------------------------------------------------------------------+
//| RESET ENGINE                                                     |
//+------------------------------------------------------------------+
void ResetEngine()
{
   realizedHedgeLoss = 0.0;

   realizedHedgeProfit = 0.0;

   hedgePeakProfit = 0.0;

   gridPeakProfit = 0.0;

   lastHedgeOpenPrice = 0.0;

   hedgeTriggeredThisCycle = false;
   lastHedgeWasLoss = false;
   lossLimitHitWaitingForHedge = false;
}

//+------------------------------------------------------------------+
//| PREPARE HEDGE                                                    |
//+------------------------------------------------------------------+
void PrepareHedge()
{
   double buyLots = 0.0;
   double sellLots = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      double lot =
      PositionGetDouble(POSITION_VOLUME);

      if(PositionGetInteger(POSITION_TYPE)
         == POSITION_TYPE_BUY)
      {
         buyLots += lot;
      }
      else
      {
         sellLots += lot;
      }
   }

   if(buyLots > sellLots)
      hedgeSignalType = ORDER_TYPE_SELL;
   else
      hedgeSignalType = ORDER_TYPE_BUY;
}

//+------------------------------------------------------------------+
//| OPEN AUTO HEDGE                                                  |
//+------------------------------------------------------------------+
void OpenAutoHedge()
{
   if(!EnableHedge)
      return;

   if(IsHedgeOpen())
      return;

   if(!MarginOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   bool result = false;

   hedgePeakProfit = 0.0;

   double lot =
   NormalizeLot(HedgeLot);

   trade.SetDeviationInPoints(HedgeCloseDeviation);

   if(hedgeSignalType == ORDER_TYPE_BUY)
   {
      result =
      trade.Buy(
         lot,
         _Symbol,
         ask,
         0,
         0,
         "HEDGE"
      );

      if(result)
      {
         lastHedgeOpenPrice = ask;
         hedgeTriggeredThisCycle = true;
         lastHedgeType = ORDER_TYPE_BUY;
         lastHedgeWasLoss = false;
      }
   }
   else
   {
      result =
      trade.Sell(
         lot,
         _Symbol,
         bid,
         0,
         0,
         "HEDGE"
      );

      if(result)
      {
         lastHedgeOpenPrice = bid;
         hedgeTriggeredThisCycle = true;
         lastHedgeType = ORDER_TYPE_SELL;
         lastHedgeWasLoss = false;
      }
   }

   trade.SetDeviationInPoints(20);
}

//+------------------------------------------------------------------+
//| CLOSE POSITION + REALIZED PL                                     |
//+------------------------------------------------------------------+
bool ClosePositionGetPL(
   ulong ticket,
   double &realizedPL
)
{
   realizedPL = 0.0;

   trade.SetDeviationInPoints(HedgeCloseDeviation);

   bool result =
   trade.PositionClose(ticket);

   trade.SetDeviationInPoints(20);

   if(!result)
      return false;

   ulong deal =
   trade.ResultDeal();

   if(deal > 0
      && HistoryDealSelect(deal))
   {
      realizedPL =
      HistoryDealGetDouble(
         deal,
         DEAL_PROFIT
      );

      realizedPL +=
      HistoryDealGetDouble(
         deal,
         DEAL_SWAP
      );

      realizedPL +=
      HistoryDealGetDouble(
         deal,
         DEAL_COMMISSION
      );
   }

   return true;
}

//+------------------------------------------------------------------+
//| MANAGE SMART HEDGE                                               |
//+------------------------------------------------------------------+
void ManageSmartHedge()
{
   if(!EnableHedge)
      return;

   double gridLoss =
   MathMax(0,-GetGridProfit());

   if(!IsHedgeOpen()
      && gridLoss >= HedgeTriggerUSD)
   {
      if(lastHedgeWasLoss && lastHedgeOpenPrice > 0)
      {
         double ask =
         SymbolInfoDouble(_Symbol,SYMBOL_ASK);

         double bid =
         SymbolInfoDouble(_Symbol,SYMBOL_BID);

         bool priceReturned = false;

         if(lastHedgeType == ORDER_TYPE_SELL)
         {
            if(ask >= lastHedgeOpenPrice)
               priceReturned = true;
         }
         else if(lastHedgeType == ORDER_TYPE_BUY)
         {
            if(bid <= lastHedgeOpenPrice)
               priceReturned = true;
         }

         if(!priceReturned)
            return;
      }

      PrepareHedge();

      OpenAutoHedge();

      return;
   }

   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsHedgePosition())
         continue;

      double profit =
      PositionGetDouble(POSITION_PROFIT);

      if(profit <= -HedgeFixedLossUSD)
      {
         double realized = 0.0;

         if(ClosePositionGetPL(ticket,realized))
         {
            realizedHedgeLoss +=
            MathAbs(realized);

            hedgePeakProfit = 0.0;

            lastHedgeWasLoss = true;
         }

         return;
      }

      if(profit > hedgePeakProfit)
         hedgePeakProfit = profit;

      if(hedgePeakProfit >= HedgeTrailStart)
      {
         double trailLevel =
         hedgePeakProfit
         - HedgeTrailStep;

         if(profit <= trailLevel)
         {
            double realized = 0.0;

            if(ClosePositionGetPL(ticket,realized))
            {
               hedgePeakProfit = 0.0;

               if(realized > 0)
                  realizedHedgeProfit += realized;
               else
                  realizedHedgeLoss += MathAbs(realized);

               lastHedgeWasLoss = false;
            }

            return;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| V4: MANAGE GRID WITH INCREMENTAL DISTANCE                        |
//+------------------------------------------------------------------+
void ManageGrid()
{
   if(IsHedgeOpen())
      return;

   if(hedgeTriggeredThisCycle)
      return;

   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   if(!CooldownOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   // V4: Get incremental distance based on current grid count
   int requiredDistance = GetIncrementalGridDistance();

   // BUY GRID

   if(currentDirection == 0)
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_BUY
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_BUY
      );

      double distance =
      (outer - bid) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Buy(
            NormalizeLot(LotSize),
            _Symbol,
            ask,
            0,
            0,
            "GridBuy"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }

   // SELL GRID

   else
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_SELL
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_SELL
      );

      double distance =
      (ask - outer) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Sell(
            NormalizeLot(LotSize),
            _Symbol,
            bid,
            0,
            0,
            "GridSell"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }
}

//+------------------------------------------------------------------+
//| OPEN FIRST TRADE                                                 |
//+------------------------------------------------------------------+
void OpenFirstTrade()
{
   if(IsHedgeOpen())
      return;

   if(hedgeTriggeredThisCycle)
      return;

   if(!AllowTrading())
      return;

   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   if(currentDirection == -1)
      currentDirection = 0;

   bool result = false;

   if(currentDirection == 0)
   {
      result =
      trade.Buy(
         NormalizeLot(LotSize),
         _Symbol,
         ask,
         0,
         0,
         "GridBuy"
      );
   }
   else
   {
      result =
      trade.Sell(
         NormalizeLot(LotSize),
         _Symbol,
         bid,
         0,
         0,
         "GridSell"
      );
   }

   if(result)
      lastTradeTime = TimeCurrent();
}

//+------------------------------------------------------------------+
//| REQUEST CLOSE ALL                                                |
//+------------------------------------------------------------------+
void RequestCloseAll(bool lossMode)
{
   closeAllPending = true;

   closeAfterLoss = lossMode;
}

//+------------------------------------------------------------------+
//| PROCESS CLOSE ALL                                                |
//+------------------------------------------------------------------+
void ProcessCloseAll()
{
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsOurPosition())
         continue;

      trade.PositionClose(ticket);
   }

   if(TotalOurPositions() == 0)
   {
      if(currentDirection == 0)
         currentDirection = 1;
      else
         currentDirection = 0;

      ResetEngine();

      if(closeAfterLoss)
      {
         PauseTradingUntil =
         TimeCurrent()
         + (RestartAfterHours * 3600);
      }

      closeAllPending = false;

      closeAfterLoss = false;
   }
}

//+------------------------------------------------------------------+
//| CHECK GRID TRAILING STOP                                         |
//+------------------------------------------------------------------+
bool CheckGridTrailingStop()
{
   if(hedgeTriggeredThisCycle)
      return false;

   double trueRecovery = GetTrueRecoveryValue();

   if(trueRecovery > gridPeakProfit)
      gridPeakProfit = trueRecovery;

   if(gridPeakProfit >= GridTrailStart)
   {
      double trailLevel = gridPeakProfit - GridTrailStep;

      if(trueRecovery <= trailLevel)
         return true;
   }

   return false;
}

//+------------------------------------------------------------------+
//| DASHBOARD                                                        |
//+------------------------------------------------------------------+
void Dashboard()
{
   double totalFloating =
   GetTotalProfit();

   double trueRecovery =
   GetTrueRecoveryValue();

   double netRealizedHedge =
   realizedHedgeProfit - realizedHedgeLoss;

   int gridCount = TotalGridPositions();
   int nextDistance = GetIncrementalGridDistance();

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   string currentTime = StringFormat("%02d:%02d:%02d", dt.hour, dt.min, dt.sec);

   bool withinHours = IsWithinTradingHours();

   int startHour, startMin, endHour, endMin;
   GetTradingHours(startHour, startMin, endHour, endMin);

   bool dayAllowed = IsTradingDayAllowed();

   string modeName;
   switch(TradingMode)
   {
      case MODE_DUAL_WINDOW: modeName = "Dual Window"; break;
      case MODE_OVERLAP_ONLY: modeName = "Overlap Only"; break;
      case MODE_FULL_LONDON: modeName = "Full London"; break;
      case MODE_PEAK_HOUR: modeName = "Peak Hour"; break;
      case MODE_CUSTOM: modeName = "Custom"; break;
      default: modeName = "Unknown"; break;
   }

   // Determine current window for DUAL_WINDOW mode
   string currentWindow = "";
   if(TradingMode == MODE_DUAL_WINDOW && withinHours)
   {
      int currentMinutes = dt.hour * 60 + dt.min;
      if(currentMinutes >= 660 && currentMinutes <= 930)
         currentWindow = "Window 1 (Early London)";
      else if(currentMinutes >= 1050 && currentMinutes <= 1170)
         currentWindow = "Window 2 (Overlap)";
   }

   // Day name
   string dayName;
   switch(dt.day_of_week)
   {
      case 0: dayName = "Sunday"; break;
      case 1: dayName = "Monday"; break;
      case 2: dayName = "Tuesday"; break;
      case 3: dayName = "Wednesday"; break;
      case 4: dayName = "Thursday"; break;
      case 5: dayName = "Friday"; break;
      case 6: dayName = "Saturday"; break;
      default: dayName = "Unknown"; break;
   }

   string closeMode;
   bool trailingActive = (gridPeakProfit >= GridTrailStart);
   if(hedgeTriggeredThisCycle)
      closeMode = "HEDGE MODE - FIXED TARGET ($" + DoubleToString(BasketProfit,2) + ")";
   else if(trailingActive)
      closeMode = "TRAILING STOP (letting profits run)";
   else
      closeMode = "FIXED TARGET ($" + DoubleToString(BasketProfit,2) + ")";

   // Build strings beforehand to avoid Comment() parameter count issues
   string windowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW)
   {
      if(dt.day_of_week == 0)  // Sunday
         windowInfo = "\nSUNDAY: NO TRADING (Market closed)";
      else if(dt.day_of_week == 6)  // Saturday
         windowInfo = "\nSATURDAY: NO TRADING (Market closes at 01:00)";
      else  // Monday-Friday
         windowInfo = "\nMON-FRI: Window 1: 11:00-15:30 UTC+3\nWindow 2: 17:30-19:30 UTC+3\nGAP SKIPPED: 15:30-17:30 UTC+3";
   }

   string currentWindowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW && currentWindow != "")
      currentWindowInfo = "\nCurrent Window: " + currentWindow;

   string dayBestTag = "";
   if(dt.day_of_week >= 2 && dt.day_of_week <= 4)
      dayBestTag = " (BEST DAY)";

   string dayStatusInfo = "";
   if(EnableDayFilter)
      dayStatusInfo = "\nDay Status: " + (dayAllowed ? "ALLOWED" : "NO TRADING");

   string blockReasons = "";
   if(!withinHours) blockReasons += "\n  >> OUTSIDE TIME WINDOW";
   if(!dayAllowed) blockReasons += "\n  >> DAY RESTRICTED";

   // Build complete dashboard incrementally to avoid expression limits
   string dashboard = "GRID + HEDGE V6 (Incr + Hedge + Pool + Trail + DUAL WINDOW + DAY FILTER)\n";

   dashboard += "\n--- TIME FILTER ---";
   dashboard += "\nTime Filter: " + (EnableTimeFilter ? "ENABLED" : "DISABLED");
   dashboard += "\nTrading Mode: " + modeName;
   dashboard += windowInfo;
   dashboard += "\nCurrent Time (MT5): " + currentTime + " (UTC+3)";
   dashboard += currentWindowInfo;
   dashboard += "\nTime Status: " + (withinHours ? "INSIDE WINDOW" : "OUTSIDE WINDOW");

   dashboard += "\n--- DAY FILTER ---";
   dashboard += "\nDay Filter: " + (EnableDayFilter ? "ENABLED" : "DISABLED");
   dashboard += "\nToday: " + dayName + dayBestTag;
   dashboard += dayStatusInfo;

   dashboard += "\n--- TRADING STATUS ---";
   dashboard += "\nOverall Status: " + ((withinHours && dayAllowed) ? "TRADING ALLOWED" : "TRADING BLOCKED");
   dashboard += blockReasons;

   dashboard += "\n\n--- INCREMENTAL GRID ---";
   dashboard += "\nGrid Positions: " + IntegerToString(gridCount);
   dashboard += "\nNext Grid Distance: " + IntegerToString(nextDistance) + " pts";
   dashboard += "\nIncrement Step: " + IntegerToString(GridIncrementStep);

   dashboard += "\n\n--- FLOATING P/L ---";
   dashboard += "\nFloating P/L: " + DoubleToString(totalFloating,2);

   dashboard += "\n\n--- HEDGE P/L TRACKING ---";
   dashboard += "\nRealized Hedge Profit: +" + DoubleToString(realizedHedgeProfit,2);
   dashboard += "\nRealized Hedge Loss: -" + DoubleToString(realizedHedgeLoss,2);
   dashboard += "\nNet Realized Hedge: " + DoubleToString(netRealizedHedge,2);

   dashboard += "\n\n--- CLOSE MODE ---";
   dashboard += "\nMode: " + closeMode;
   dashboard += "\nGrid Peak Profit: $" + DoubleToString(gridPeakProfit,2);
   dashboard += "\nTrail Activates At: $" + DoubleToString(GridTrailStart,2);
   dashboard += "\nTrail Step: $" + DoubleToString(GridTrailStep,2);
   if(trailingActive && !hedgeTriggeredThisCycle)
      dashboard += "\nTrail Level: $" + DoubleToString(gridPeakProfit - GridTrailStep,2) + " (closes if profit drops here)";
   else if(hedgeTriggeredThisCycle)
      dashboard += "\nTrail Level: N/A (Hedge mode uses fixed target)";
   else
      dashboard += "\nTrail Level: Not Active (profit < $" + DoubleToString(GridTrailStart,2) + ")";

   dashboard += "\n\n--- TRUE RECOVERY ---";
   dashboard += "\nTrue Recovery Value: " + DoubleToString(trueRecovery,2);
   dashboard += "\nFixed Target: " + DoubleToString(BasketProfit,2);

   dashboard += "\n\n--- STATUS ---";
   dashboard += "\nHedge Open: " + (IsHedgeOpen() ? "YES" : "NO");
   dashboard += "\nHedge Triggered: " + (hedgeTriggeredThisCycle ? "YES" : "NO");
   dashboard += "\nLoss Limit Waiting: " + (lossLimitHitWaitingForHedge ? "YES" : "NO");

   dashboard += "\n\nNOTE: DST automatically handled by MT5 broker time";

   Comment(dashboard);
}

//+------------------------------------------------------------------+
//| ON TICK                                                          |
//+------------------------------------------------------------------+
void OnTick()
{
   // STEP 1: Handle pending close operations
   if(closeAllPending)
   {
      ProcessCloseAll();
      Dashboard();
      return;
   }

   // STEP 2: Check if we're in pause mode (after stop loss)
   if(PauseTradingUntil > 0 && TimeCurrent() < PauseTradingUntil)
   {
      Dashboard();
      return;
   }

   // STEP 3: Determine if we can open NEW positions
   bool canOpenNewPositions = true;

   if(!IsTradingDayAllowed())
      canOpenNewPositions = false;

   if(!IsWithinTradingHours())
      canOpenNewPositions = false;

   if(!AllowTrading())
      canOpenNewPositions = false;

   // STEP 4: Handle special state - loss limit hit, waiting for hedge to recover
   if(lossLimitHitWaitingForHedge)
   {
      double trueRecovery = GetTrueRecoveryValue();

      // Check if we've recovered enough to close
      if(trueRecovery >= BasketProfit)
      {
         Print("RECOVERY TARGET reached: TrueRecovery=", trueRecovery, " Target=", BasketProfit);
         RequestCloseAll(false);
         Dashboard();
         return;
      }

      // Manage hedge if open
      if(IsHedgeOpen())
      {
         ManageSmartHedge();
         Dashboard();
         return;
      }

      // Hedge closed but didn't reach target - reset and pause
      if(currentDirection == 0)
         currentDirection = 1;
      else
         currentDirection = 0;

      PauseTradingUntil = TimeCurrent() + (RestartAfterHours * 3600);
      ResetEngine();
      Dashboard();
      return;
   }

   // STEP 5: Get position counts
   int totalPositions = TotalOurPositions();
   bool hedgeOpen = IsHedgeOpen();

   // STEP 6: If we have active positions, ALWAYS manage them (regardless of trading hours)
   if(totalPositions > 0)
   {
      // Always manage hedge if open
      if(hedgeOpen)
      {
         ManageSmartHedge();
      }

      // Get current values for close checks
      double gridProfit = GetGridProfit();
      double trueRecovery = GetTrueRecoveryValue();

      // Update peak profit tracking for trailing stop
      if(gridProfit > gridPeakProfit)
         gridPeakProfit = gridProfit;

      // CASE A: Hedge was triggered this cycle - use true recovery for profit target
      if(hedgeTriggeredThisCycle)
      {
         if(trueRecovery >= BasketProfit)
         {
            Print("HEDGE MODE - FIXED TARGET reached: TrueRecovery=", trueRecovery, " Target=", BasketProfit);
            RequestCloseAll(false);
            Dashboard();
            return;
         }

         // If only hedge position remains (grid closed)
         if(totalPositions == 1 && hedgeOpen)
         {
            Dashboard();
            return;  // Just manage hedge, wait for profit target
         }
      }
      // CASE B: No hedge triggered - use TRAILING ONLY (no fixed profit target)
      else
      {
         // Wait for profit to reach GridTrailStart, then trail by GridTrailStep
         if(gridPeakProfit >= GridTrailStart)
         {
            // TRAILING MODE ACTIVE: Close when profit drops GridTrailStep from peak
            double trailLevel = gridPeakProfit - GridTrailStep;

            if(gridProfit <= trailLevel)
            {
               Print("TRAILING STOP triggered: Peak=", gridPeakProfit, " Current=", gridProfit, " TrailLevel=", trailLevel);
               RequestCloseAll(false);
               Dashboard();
               return;
            }
            // Let profits run until trail level is hit
         }
         // If trailing not yet active, just wait (no fixed profit target)
      }

      // CHECK GRID LOSS LIMIT (triggers hedge)
      if(!hedgeOpen && !hedgeTriggeredThisCycle)
      {
         if(gridProfit <= BasketLossLimit)
         {
            Print("GRID LOSS LIMIT reached: GridProfit=", gridProfit, " Limit=", BasketLossLimit);
            CloseOnlyGridPositions();

            if(IsHedgeOpen())
            {
               lossLimitHitWaitingForHedge = true;
            }
            else
            {
               // FIX: Switch direction when stop loss hit without hedge
               if(currentDirection == 0)
                  currentDirection = 1;
               else
                  currentDirection = 0;

               ResetEngine();  // Reset flags for new cycle

               PauseTradingUntil = TimeCurrent() + (RestartAfterHours * 3600);
            }
            Dashboard();
            return;
         }
      }

      // If outside trading hours but have positions
      if(!canOpenNewPositions)
      {
         if(ClosePositionsOutsideHours)
         {
            Print("OUTSIDE HOURS - Force closing all positions");
            RequestCloseAll(false);
         }
         // Else: Keep positions open but don't add new grid levels
         Dashboard();
         return;
      }

      // Inside trading hours with active positions
      if(!hedgeOpen)
      {
         ManageGrid();  // Add grid levels if needed
      }

      Dashboard();
      return;
   }

   // STEP 7: No positions - check if we can open new ones
   if(totalPositions == 0)
   {
      // Reset for new cycle
      if(hedgeTriggeredThisCycle)
      {
         if(currentDirection == 0)
            currentDirection = 1;
         else
            currentDirection = 0;
         ResetEngine();
      }
      else if(gridPeakProfit > 0)
      {
         gridPeakProfit = 0.0;  // Reset peak profit for new cycle
      }

      if(canOpenNewPositions)
      {
         OpenFirstTrade();
      }
      // Else: Wait for trading hours

      Dashboard();
      return;
   }

   Dashboard();
}
