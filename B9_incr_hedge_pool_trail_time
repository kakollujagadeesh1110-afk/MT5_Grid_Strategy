//+------------------------------------------------------------------+
//| TRUE RECOVERY VALUE                                              |
//+------------------------------------------------------------------+
double GetTrueRecoveryValue()
{
   double floatingPL = GetTotalProfit();

   double netRealizedHedge = realizedHedgeProfit - realizedHedgeLoss;

   return floatingPL + netRealizedHedge;
}

//+------------------------------------------------------------------+
//| HEDGE OPEN CHECK                                                 |
//+------------------------------------------------------------------+
bool IsHedgeOpen()
{
   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(IsHedgePosition())
