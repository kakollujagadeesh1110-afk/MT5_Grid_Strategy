//+------------------------------------------------------------------+
//| V6: GET TRADING HOURS BASED ON MODE                              |
//+------------------------------------------------------------------+
void GetTradingHours(int &startHour, int &startMin, int &endHour, int &endMin)
{
   switch(TradingMode)
   {
      case MODE_DUAL_WINDOW:
         // For dual window, return Window 1 times
         // (Window 2 is checked separately in IsWithinTradingHours)
         startHour = 11;
         startMin = 0;
         endHour = 15;
         endMin = 30;
         break;

      case MODE_OVERLAP_ONLY:
         startHour = 17;
         startMin = 30;
         endHour = 19;
         endMin = 30;
         break;

      case MODE_FULL_LONDON:
         startHour = 11;
         startMin = 0;
         endHour = 19;
         endMin = 30;
         break;

      case MODE_PEAK_HOUR:
         startHour = 17;
         startMin = 30;
         endHour = 18;
         endMin = 30;
         break;

      case MODE_CUSTOM:
         startHour = CustomStartHour;
         startMin = CustomStartMinute;
         endHour = CustomEndHour;
         endMin = CustomEndMinute;
         break;

      default:
         // Default to dual window
         startHour = 11;
         startMin = 0;
         endHour = 15;
         endMin = 30;
         break;
   }
}

//+------------------------------------------------------------------+
//| V7: CHECK IF WITHIN TRADING HOURS                                |
//| MT5 broker time shows UTC+3 with auto DST handling               |
//| V7: Day-aware dual window mode with Monday/Saturday handling     |
//+------------------------------------------------------------------+
bool IsWithinTradingHours()
{
   if(!EnableTimeFilter)
      return true;  // No filter, always allow trading

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   int currentMinutes = dt.hour * 60 + dt.min;

   // V7: Special handling for MODE_DUAL_WINDOW with day-specific windows
   if(TradingMode == MODE_DUAL_WINDOW)
   {
      // SATURDAY: Special window before market close (00:00-01:00 UTC+3)
      if(dt.day_of_week == 6)
      {
         int saturdayEnd = FridayEndHour * 60;  // 01:00 = 60 minutes
         return (currentMinutes < saturdayEnd);
      }

      // MONDAY: Extended Window 1 (starts at 05:00 instead of 11:00)
      if(dt.day_of_week == 1)
      {
         // Window 1: 05:00 - 15:30 (Monday extended after gap settlement)
         int window1Start = MondayStartHour * 60 + 0;  // 05:00 = 300 minutes
         int window1End = 15 * 60 + 30;                // 15:30 = 930 minutes

         // Window 2: 17:30 - 19:30 (same as other days)
         int window2Start = 17 * 60 + 30;    // 1050 minutes
         int window2End = 19 * 60 + 30;      // 1170 minutes

         bool inWindow1 = (currentMinutes >= window1Start) && (currentMinutes <= window1End);
         bool inWindow2 = (currentMinutes >= window2Start) && (currentMinutes <= window2End);

         return inWindow1 || inWindow2;
      }

      // TUESDAY-FRIDAY: Standard dual window
      // Window 1: 11:00 - 15:30 (Early London)
      int window1Start = 11 * 60 + 0;    // 660 minutes
      int window1End = 15 * 60 + 30;      // 930 minutes

      // Window 2: 17:30 - 19:30 (London-NY Overlap)
      int window2Start = 17 * 60 + 30;    // 1050 minutes
      int window2End = 19 * 60 + 30;     // 1170 minutes

      // Check if in either window
      bool inWindow1 = (currentMinutes >= window1Start) && (currentMinutes <= window1End);
      bool inWindow2 = (currentMinutes >= window2Start) && (currentMinutes <= window2End);

      return inWindow1 || inWindow2;
   }

   // For all other modes, use single window check
   int startHour, startMin, endHour, endMin;
   GetTradingHours(startHour, startMin, endHour, endMin);

   int startMinutes = startHour * 60 + startMin;
   int endMinutes = endHour * 60 + endMin;

   // Handle case where end time is past midnight (crosses day boundary)
   if(endMinutes < startMinutes)
   {
      // e.g., 22:00 to 02:00 next day
      return (currentMinutes >= startMinutes) || (currentMinutes <= endMinutes);
   }
   else
   {
      // Normal case: 3:00 to 11:30 or 9:30 to 11:30
      return (currentMinutes >= startMinutes) && (currentMinutes <= endMinutes);
   }
}

//+------------------------------------------------------------------+
//| V7: CHECK DAY-OF-WEEK FILTER                                     |
//| Returns true if trading allowed based on day restrictions        |
//| NOTE: Monday/Saturday timing handled by IsWithinTradingHours()   |
//+------------------------------------------------------------------+
bool IsTradingDayAllowed()
{
   if(!EnableDayFilter)
      return true;  // No day filter, always allow

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   // dt.day_of_week: 0=Sunday, 1=Monday, 2=Tuesday, ..., 6=Saturday

   // Sunday - no trading (market closed)
   if(dt.day_of_week == 0)
      return false;

   // Saturday - check if market is still open (closes at 01:00 UTC+3)
   // Time window check is in IsWithinTradingHours(), but block entirely after market close
   if(dt.day_of_week == 6 && StopFridayLate)
   {
      if(dt.hour >= FridayEndHour)
         return false;  // Market closed
   }

   // Monday-Friday: Allow (time windows handled by IsWithinTradingHours)
   return true;
}

//+------------------------------------------------------------------+
//| NORMALIZE LOT                                                    |
//+------------------------------------------------------------------+
double NormalizeLot(double lot)
{
   double minLot =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MIN);

   double maxLot =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MAX);

   double step =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_STEP);

   if(lot < minLot)
      lot = minLot;

   if(lot > maxLot)
      lot = maxLot;

   lot =
   MathFloor(lot / step) * step;

   return NormalizeDouble(lot,2);
}

//+------------------------------------------------------------------+
//| IS OUR POSITION                                                  |
//+------------------------------------------------------------------+
bool IsOurPosition()
{
   if(PositionGetString(POSITION_SYMBOL)
      != _Symbol)
      return false;

   if((ulong)PositionGetInteger(POSITION_MAGIC)
      != MagicNumber)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| IS GRID POSITION                                                 |
//+------------------------------------------------------------------+
bool IsGridPosition()
{
   if(!IsOurPosition())
      return false;

   string c =
   PositionGetString(POSITION_COMMENT);

   if(c == "GridBuy"
      || c == "GridSell")
      return true;

   return false;
}

//+------------------------------------------------------------------+
//| IS HEDGE POSITION                                                |
//+------------------------------------------------------------------+
bool IsHedgePosition()
{
   if(!IsOurPosition())
      return false;

   if(PositionGetString(POSITION_COMMENT)
      == "HEDGE")
      return true;

   return false;
}

//+------------------------------------------------------------------+
//| SPREAD CHECK                                                     |
//+------------------------------------------------------------------+
bool SpreadOK()
{
   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   double spread =
   (ask - bid) / _Point;

   if(spread > MaxSpreadPoints)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| MARGIN CHECK                                                     |
//+------------------------------------------------------------------+
bool MarginOK()
{
   double ml =
   AccountInfoDouble(ACCOUNT_MARGIN_LEVEL);

   if(ml <= 0)
      return true;

   if(ml < MinMarginLevel)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| ALLOW TRADING                                                    |
//+------------------------------------------------------------------+
bool AllowTrading()
{
   if(AccountInfoDouble(ACCOUNT_BALANCE)
      >= StopTradingBalance)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| COOLDOWN CHECK                                                   |
//+------------------------------------------------------------------+
bool CooldownOK()
{
   if(TimeCurrent() - lastTradeTime
      < TradeCooldownSeconds)
      return false;

   return true;
}

