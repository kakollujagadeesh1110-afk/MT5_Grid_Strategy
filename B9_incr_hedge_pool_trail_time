//+------------------------------------------------------------------+
//| CLOSE ONLY GRID POSITIONS                                        |
//+------------------------------------------------------------------+
void CloseOnlyGridPositions()
{
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      trade.PositionClose(ticket);
   }
}

//+------------------------------------------------------------------+
//| OUTERMOST GRID PRICE                                             |
//+------------------------------------------------------------------+
double GetOuterGridPrice(int type)
{
   bool found = false;

   double price = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      if(PositionGetInteger(POSITION_TYPE)
         != type)
         continue;

      double p =
      PositionGetDouble(POSITION_PRICE_OPEN);

      if(!found)
      {
         found = true;
         price = p;
      }
      else
      {
         if(type == POSITION_TYPE_BUY
            && p < price)
            price = p;

         if(type == POSITION_TYPE_SELL
            && p > price)
            price = p;
      }
   }

   return price;
}

//+------------------------------------------------------------------+
//| V4: GET INCREMENTAL GRID DISTANCE                                |
//| Distance = GridIncrementStep × CurrentGridCount                  |
//+------------------------------------------------------------------+
int GetIncrementalGridDistance()
{
   int gridCount = TotalGridPositions();

   // If no grid yet, first distance is 1 × Step
   if(gridCount == 0)
      gridCount = 1;

   return GridIncrementStep * gridCount;
}

//+------------------------------------------------------------------+
//| RESET ENGINE                                                     |
//+------------------------------------------------------------------+
void ResetEngine()
{
   realizedHedgeLoss = 0.0;

   realizedHedgeProfit = 0.0;

   hedgePeakProfit = 0.0;

   gridPeakProfit = 0.0;

   lastHedgeOpenPrice = 0.0;

   hedgeTriggeredThisCycle = false;
   lastHedgeWasLoss = false;
   lossLimitHitWaitingForHedge = false;
}

//+------------------------------------------------------------------+
//| PREPARE HEDGE                                                    |
//+------------------------------------------------------------------+
void PrepareHedge()
{
   double buyLots = 0.0;
   double sellLots = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      double lot =
      PositionGetDouble(POSITION_VOLUME);

      if(PositionGetInteger(POSITION_TYPE)
         == POSITION_TYPE_BUY)
      {
         buyLots += lot;
      }
      else
      {
         sellLots += lot;
      }
   }

   if(buyLots > sellLots)
      hedgeSignalType = ORDER_TYPE_SELL;
   else
      hedgeSignalType = ORDER_TYPE_BUY;
}

//+------------------------------------------------------------------+
//| OPEN AUTO HEDGE                                                  |
//+------------------------------------------------------------------+
void OpenAutoHedge()
{
   if(!EnableHedge)
      return;

   if(IsHedgeOpen())
      return;

   if(!MarginOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   bool result = false;

   hedgePeakProfit = 0.0;

   double lot =
   NormalizeLot(HedgeLot);

   trade.SetDeviationInPoints(HedgeCloseDeviation);

   if(hedgeSignalType == ORDER_TYPE_BUY)
   {
      result =
      trade.Buy(
         lot,
         _Symbol,
         ask,
         0,
         0,
         "HEDGE"
      );

      if(result)
      {
         lastHedgeOpenPrice = ask;
         hedgeTriggeredThisCycle = true;
         lastHedgeType = ORDER_TYPE_BUY;
         lastHedgeWasLoss = false;
      }
   }
   else
   {
      result =
      trade.Sell(
         lot,
         _Symbol,
         bid,
         0,
         0,
         "HEDGE"
      );

      if(result)
      {
         lastHedgeOpenPrice = bid;
         hedgeTriggeredThisCycle = true;
         lastHedgeType = ORDER_TYPE_SELL;
         lastHedgeWasLoss = false;
      }
   }

   trade.SetDeviationInPoints(20);
}

//+------------------------------------------------------------------+
//| CLOSE POSITION + REALIZED PL                                     |
//+------------------------------------------------------------------+
bool ClosePositionGetPL(
   ulong ticket,
   double &realizedPL
)
{
   realizedPL = 0.0;

   trade.SetDeviationInPoints(HedgeCloseDeviation);

   bool result =
   trade.PositionClose(ticket);

   trade.SetDeviationInPoints(20);

   if(!result)
      return false;

   ulong deal =
   trade.ResultDeal();

   if(deal > 0
      && HistoryDealSelect(deal))
   {
      realizedPL =
      HistoryDealGetDouble(
         deal,
         DEAL_PROFIT
      );

      realizedPL +=
      HistoryDealGetDouble(
         deal,
         DEAL_SWAP
      );

      realizedPL +=
      HistoryDealGetDouble(
         deal,
         DEAL_COMMISSION
      );
   }

   return true;
}

//+------------------------------------------------------------------+
//| MANAGE SMART HEDGE                                               |
//+------------------------------------------------------------------+
void ManageSmartHedge()
{
   if(!EnableHedge)
      return;

   double gridLoss =
   MathMax(0,-GetGridProfit());

   if(!IsHedgeOpen()
      && gridLoss >= HedgeTriggerUSD)
   {
      if(lastHedgeWasLoss && lastHedgeOpenPrice > 0)
      {
         double ask =
         SymbolInfoDouble(_Symbol,SYMBOL_ASK);

         double bid =
         SymbolInfoDouble(_Symbol,SYMBOL_BID);

         bool priceReturned = false;

         if(lastHedgeType == ORDER_TYPE_SELL)
         {
            if(ask >= lastHedgeOpenPrice)
               priceReturned = true;
         }
         else if(lastHedgeType == ORDER_TYPE_BUY)
         {
            if(bid <= lastHedgeOpenPrice)
               priceReturned = true;
         }

         if(!priceReturned)
            return;
      }

      PrepareHedge();

      OpenAutoHedge();

      return;
   }

   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsHedgePosition())
         continue;

      double profit =
      PositionGetDouble(POSITION_PROFIT);

      if(profit <= -HedgeFixedLossUSD)
      {
         double realized = 0.0;

         if(ClosePositionGetPL(ticket,realized))
         {
            realizedHedgeLoss +=
            MathAbs(realized);

            hedgePeakProfit = 0.0;

            lastHedgeWasLoss = true;
         }

         return;
      }

      if(profit > hedgePeakProfit)
         hedgePeakProfit = profit;

      if(hedgePeakProfit >= HedgeTrailStart)
      {
         double trailLevel =
         hedgePeakProfit
         - HedgeTrailStep;

         if(profit <= trailLevel)
         {
            double realized = 0.0;

            if(ClosePositionGetPL(ticket,realized))
            {
               hedgePeakProfit = 0.0;

               if(realized > 0)
                  realizedHedgeProfit += realized;
               else
                  realizedHedgeLoss += MathAbs(realized);

               lastHedgeWasLoss = false;
            }

            return;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| V4: MANAGE GRID WITH INCREMENTAL DISTANCE                        |
//+------------------------------------------------------------------+
void ManageGrid()
{
   if(IsHedgeOpen())
      return;

   if(hedgeTriggeredThisCycle)
      return;

   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   if(!CooldownOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   // V4: Get incremental distance based on current grid count
   int requiredDistance = GetIncrementalGridDistance();

   // BUY GRID

   if(currentDirection == 0)
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_BUY
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_BUY
      );

      double distance =
      (outer - bid) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Buy(
            NormalizeLot(LotSize),
            _Symbol,
            ask,
            0,
            0,
            "GridBuy"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }

   // SELL GRID

   else
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_SELL
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_SELL
      );

      double distance =
      (ask - outer) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Sell(
            NormalizeLot(LotSize),
            _Symbol,
            bid,
            0,
            0,
            "GridSell"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }
}

//+------------------------------------------------------------------+
//| OPEN FIRST TRADE                                                 |
//+------------------------------------------------------------------+
void OpenFirstTrade()
{
   if(IsHedgeOpen())
      return;

   if(hedgeTriggeredThisCycle)
      return;

   if(!AllowTrading())
      return;

   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   if(currentDirection == -1)
      currentDirection = 0;

   bool result = false;

   if(currentDirection == 0)
   {
      result =
      trade.Buy(
         NormalizeLot(LotSize),
         _Symbol,
         ask,
         0,
         0,
         "GridBuy"
      );
   }
   else
   {
      result =
      trade.Sell(
         NormalizeLot(LotSize),
         _Symbol,
         bid,
         0,
         0,
         "GridSell"
      );
   }

   if(result)
      lastTradeTime = TimeCurrent();
}

//+------------------------------------------------------------------+
//| REQUEST CLOSE ALL                                                |
//+------------------------------------------------------------------+
void RequestCloseAll(bool lossMode)
{
   closeAllPending = true;

   closeAfterLoss = lossMode;
}

//+------------------------------------------------------------------+
//| PROCESS CLOSE ALL                                                |
//+------------------------------------------------------------------+
void ProcessCloseAll()
{
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsOurPosition())
         continue;

      trade.PositionClose(ticket);
   }

   if(TotalOurPositions() == 0)
   {
      if(currentDirection == 0)
         currentDirection = 1;
      else
         currentDirection = 0;

      ResetEngine();

      if(closeAfterLoss)
      {
         PauseTradingUntil =
         TimeCurrent()
         + (RestartAfterHours * 3600);
      }

      closeAllPending = false;

      closeAfterLoss = false;
   }
}

//+------------------------------------------------------------------+
//| CHECK GRID TRAILING STOP                                         |
//+------------------------------------------------------------------+
bool CheckGridTrailingStop()
{
   if(hedgeTriggeredThisCycle)
      return false;

   double trueRecovery = GetTrueRecoveryValue();

   if(trueRecovery > gridPeakProfit)
      gridPeakProfit = trueRecovery;

   if(gridPeakProfit >= GridTrailStart)
   {
      double trailLevel = gridPeakProfit - GridTrailStep;

      if(trueRecovery <= trailLevel)
         return true;
   }

   return false;
}

//+------------------------------------------------------------------+
//| DASHBOARD                                                        |
//+------------------------------------------------------------------+
void Dashboard()
{
   double totalFloating =
   GetTotalProfit();

   double trueRecovery =
   GetTrueRecoveryValue();

   double netRealizedHedge =
   realizedHedgeProfit - realizedHedgeLoss;

   int gridCount = TotalGridPositions();
   int nextDistance = GetIncrementalGridDistance();

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   string currentTime = StringFormat("%02d:%02d:%02d", dt.hour, dt.min, dt.sec);

   bool withinHours = IsWithinTradingHours();

   int startHour, startMin, endHour, endMin;
   GetTradingHours(startHour, startMin, endHour, endMin);

   bool dayAllowed = IsTradingDayAllowed();
   bool manualPause = IsManuallyPaused();

   string modeName;
   switch(TradingMode)
   {
      case MODE_DUAL_WINDOW: modeName = "Dual Window"; break;
      case MODE_OVERLAP_ONLY: modeName = "Overlap Only"; break;
      case MODE_FULL_LONDON: modeName = "Full London"; break;
      case MODE_PEAK_HOUR: modeName = "Peak Hour"; break;
      case MODE_CUSTOM: modeName = "Custom"; break;
      default: modeName = "Unknown"; break;
   }

   // Determine current window for DUAL_WINDOW mode
   string currentWindow = "";
   if(TradingMode == MODE_DUAL_WINDOW && withinHours)
   {
      int currentMinutes = dt.hour * 60 + dt.min;
      if(currentMinutes >= 180 && currentMinutes <= 450)
         currentWindow = "Window 1 (Early London)";
      else if(currentMinutes >= 570 && currentMinutes <= 690)
         currentWindow = "Window 2 (Overlap)";
   }

   // Day name
   string dayName;
   switch(dt.day_of_week)
   {
      case 0: dayName = "Sunday"; break;
      case 1: dayName = "Monday"; break;
      case 2: dayName = "Tuesday"; break;
      case 3: dayName = "Wednesday"; break;
      case 4: dayName = "Thursday"; break;
      case 5: dayName = "Friday"; break;
      case 6: dayName = "Saturday"; break;
      default: dayName = "Unknown"; break;
   }

   string closeMode;
   if(hedgeTriggeredThisCycle)
      closeMode = "FIXED TARGET";
   else
      closeMode = "TRAILING STOP";

   // Build strings beforehand to avoid Comment() parameter count issues
   string windowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW)
      windowInfo = "\nWindow 1: 03:00-07:30 (Early London)\nWindow 2: 09:30-11:30 (Overlap)\nGAP SKIPPED: 07:30-09:30";

   string currentWindowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW && currentWindow != "")
      currentWindowInfo = "\nCurrent Window: " + currentWindow;

   string dayBestTag = "";
   if(dt.day_of_week >= 2 && dt.day_of_week <= 4)
      dayBestTag = " (BEST DAY)";

   string dayStatusInfo = "";
   if(EnableDayFilter)
      dayStatusInfo = "\nDay Status: " + (dayAllowed ? "ALLOWED" : "RESTRICTED");

   string mondayInfo = "";
   if(dt.day_of_week == 1 && SkipMondayEarly)
      mondayInfo = StringFormat("\nMonday Skip: Before %02d:00", MondayStartHour);

   string fridayInfo = "";
   if(dt.day_of_week == 5 && StopFridayLate)
      fridayInfo = StringFormat("\nFriday Stop: After %02d:00", FridayEndHour);

   string pauseAction = manualPause ? "\nSet to 0 to RESUME" : "\nSet to 1 to PAUSE";

   string blockReasons = "";
   if(!withinHours) blockReasons += "\n  >> OUTSIDE TIME WINDOW";
   if(!dayAllowed) blockReasons += "\n  >> DAY RESTRICTED";
   if(manualPause) blockReasons += "\n  >> MANUALLY PAUSED";

   Comment(
      "GRID + HEDGE V6 (Incr + Hedge + Pool + Trail + DUAL WINDOW + DAY FILTER)\n",
      "\n--- TIME FILTER ---",
      "\nTime Filter: ", EnableTimeFilter ? "ENABLED" : "DISABLED",
      "\nTrading Mode: ", modeName,
      windowInfo,
      "\nCurrent Time (MT5): ", currentTime, " (US EST/EDT)",
      currentWindowInfo,
      "\nTime Status: ", withinHours ? "INSIDE WINDOW" : "OUTSIDE WINDOW",

      "\n--- DAY FILTER ---",
      "\nDay Filter: ", EnableDayFilter ? "ENABLED" : "DISABLED",
      "\nToday: ", dayName, dayBestTag,
      dayStatusInfo,
      mondayInfo,
      fridayInfo,

      "\n--- MANUAL CONTROL ---",
      "\nManual Pause: ", manualPause ? "ON (PAUSED)" : "OFF",
      "\nControl: Press F3 > ", ManualPauseVarName,
      pauseAction,

      "\n--- TRADING STATUS ---",
      "\nOverall Status: ", (withinHours && dayAllowed && !manualPause) ? "TRADING ALLOWED" : "TRADING BLOCKED",
      blockReasons,

      "\n\n--- INCREMENTAL GRID ---",

      "\nGrid Positions: ",
      IntegerToString(gridCount),

      "\nNext Grid Distance: ",
      IntegerToString(nextDistance),
      " pts",

      "\nIncrement Step: ",
      IntegerToString(GridIncrementStep),

      "\n\n--- FLOATING P/L ---",

      "\nFloating P/L: ",
      DoubleToString(totalFloating,2),

      "\n\n--- HEDGE P/L TRACKING ---",

      "\nRealized Hedge Profit: +",
      DoubleToString(realizedHedgeProfit,2),

      "\nRealized Hedge Loss: -",
      DoubleToString(realizedHedgeLoss,2),

      "\nNet Realized Hedge: ",
      DoubleToString(netRealizedHedge,2),

      "\n\n--- CLOSE MODE ---",

      "\nMode: ",
      closeMode,

      "\nGrid Peak Profit: ",
      DoubleToString(gridPeakProfit,2),

      "\nTrail Level: ",
      (gridPeakProfit >= GridTrailStart)
      ? DoubleToString(gridPeakProfit - GridTrailStep,2)
      : "Not Active",

      "\n\n--- TRUE RECOVERY ---",

      "\nTrue Recovery Value: ",
      DoubleToString(trueRecovery,2),

      "\nFixed Target: ",
      DoubleToString(BasketProfit,2),

      "\n\n--- STATUS ---",

      "\nHedge Open: ",
      IsHedgeOpen()
      ? "YES"
      : "NO",

      "\nHedge Triggered: ",
      hedgeTriggeredThisCycle
      ? "YES"
      : "NO",

      "\nLoss Limit Waiting: ",
      lossLimitHitWaitingForHedge
      ? "YES"
      : "NO",

      "\n\nNOTE: DST automatically handled by MT5 broker time"
   );
}

//+------------------------------------------------------------------+
//| ON TICK                                                          |
//+------------------------------------------------------------------+
void OnTick()
{
   if(closeAllPending)
   {
      ProcessCloseAll();

      Dashboard();

      return;
   }

   if(PauseTradingUntil > 0
      && TimeCurrent() < PauseTradingUntil)
   {
      Dashboard();

      return;
   }

   // V6: MANUAL PAUSE CHECK (highest priority)
   if(IsManuallyPaused())
   {
      Dashboard();  // Show paused status
      return;        // Stop all trading logic
   }

   // V6: DAY FILTER CHECK
   if(!IsTradingDayAllowed())
   {
      Dashboard();  // Show day restriction status
      return;        // Stop trading on restricted days/times
   }

   // V6: TIME FILTER CHECK
   if(!IsWithinTradingHours())
   {
      // If outside trading hours and we have positions
      if(ClosePositionsOutsideHours && TotalOurPositions() > 0)
      {
         RequestCloseAll(false);  // Close without pause

         Dashboard();

         return;
      }

      // Just show dashboard and wait
      Dashboard();

      return;
   }

   if(lossLimitHitWaitingForHedge)
   {
      double trueRecovery = GetTrueRecoveryValue();

      if(trueRecovery >= BasketProfit)
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }

      if(IsHedgeOpen())
      {
         ManageSmartHedge();

         Dashboard();

         return;
      }

      if(currentDirection == 0)
         currentDirection = 1;
      else
         currentDirection = 0;

      PauseTradingUntil =
      TimeCurrent()
      + (RestartAfterHours * 3600);

      ResetEngine();

      Dashboard();

      return;
   }

   if(!AllowTrading())
   {
      Dashboard();

      return;
   }

   if(TotalOurPositions() == 1
      && IsHedgeOpen())
   {
      double trueRecovery = GetTrueRecoveryValue();

      if(trueRecovery >= BasketProfit)
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }

      ManageSmartHedge();

      Dashboard();

      return;
   }

   if(TotalOurPositions() == 0)
   {
      if(hedgeTriggeredThisCycle)
      {
         if(currentDirection == 0)
            currentDirection = 1;
         else
            currentDirection = 0;

         ResetEngine();
      }

      OpenFirstTrade();

      Dashboard();

      return;
   }

   ManageSmartHedge();

   double trueRecovery = GetTrueRecoveryValue();

   if(hedgeTriggeredThisCycle)
   {
      if(trueRecovery >= BasketProfit)
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }
   }
   else
   {
      // NO HEDGE: Use ONLY grid trailing stop (not profit target)
      // Profit target only applies when hedge is triggered
      if(CheckGridTrailingStop())
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }
   }

   if(IsHedgeOpen())
   {
      Dashboard();

      return;
   }

   ManageGrid();

   double gridFloating =
   GetGridProfit();

   if(gridFloating <= BasketLossLimit)
   {
      CloseOnlyGridPositions();

      if(IsHedgeOpen())
      {
         lossLimitHitWaitingForHedge = true;
      }
      else
      {
         PauseTradingUntil =
         TimeCurrent()
         + (RestartAfterHours * 3600);
      }
   }

   Dashboard();
}
