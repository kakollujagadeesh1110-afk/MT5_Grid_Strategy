      "\nTrail Level: ",
      (gridPeakProfit >= GridTrailStart)
      ? DoubleToString(gridPeakProfit - GridTrailStep,2)
      : "Not Active",

      "\n\n--- TRUE RECOVERY ---",

      "\nTrue Recovery Value: ",
      DoubleToString(trueRecovery,2),

      "\nFixed Target: ",
      DoubleToString(BasketProfit,2),

      "\n\n--- STATUS ---",

      "\nHedge Open: ",
      IsHedgeOpen()
      ? "YES"
      : "NO",

      "\nHedge Triggered: ",
      hedgeTriggeredThisCycle
      ? "YES"
      : "NO",

      "\nLoss Limit Waiting: ",
      lossLimitHitWaitingForHedge
      ? "YES"
      : "NO",

      "\n\nNOTE: DST automatically handled by MT5 broker time"
   );
}

//+------------------------------------------------------------------+
//| ON TICK                                                          |
//+------------------------------------------------------------------+
void OnTick()
{
   if(closeAllPending)
   {
      ProcessCloseAll();

      Dashboard();

      return;
   }

   if(PauseTradingUntil > 0
      && TimeCurrent() < PauseTradingUntil)
   {
      Dashboard();

      return;
   }

   // V5: TIME FILTER CHECK
   if(!IsWithinTradingHours())
   {
      // If outside trading hours and we have positions
      if(ClosePositionsOutsideHours && TotalOurPositions() > 0)
      {
         RequestCloseAll(false);  // Close without pause

         Dashboard();

         return;
      }

      // Just show dashboard and wait
      Dashboard();

      return;
   }

   if(lossLimitHitWaitingForHedge)
   {
      double trueRecovery = GetTrueRecoveryValue();

      if(trueRecovery >= BasketProfit)
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }

      if(IsHedgeOpen())
      {
         ManageSmartHedge();

         Dashboard();

         return;
      }

      if(currentDirection == 0)
         currentDirection = 1;
      else
         currentDirection = 0;

      PauseTradingUntil =
      TimeCurrent()
      + (RestartAfterHours * 3600);

      ResetEngine();

      Dashboard();

      return;
   }

   if(!AllowTrading())
   {
      Dashboard();

      return;
   }

   if(TotalOurPositions() == 1
      && IsHedgeOpen())
   {
      double trueRecovery = GetTrueRecoveryValue();

      if(trueRecovery >= BasketProfit)
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }

      ManageSmartHedge();

      Dashboard();

      return;
   }

   if(TotalOurPositions() == 0)
   {
      if(hedgeTriggeredThisCycle)
      {
         if(currentDirection == 0)
            currentDirection = 1;
         else
            currentDirection = 0;

         ResetEngine();
      }

      OpenFirstTrade();

      Dashboard();

      return;
   }

   ManageSmartHedge();

   double trueRecovery = GetTrueRecoveryValue();

   if(hedgeTriggeredThisCycle)
   {
      if(trueRecovery >= BasketProfit)
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }
   }
   else
   {
      // NO HEDGE: Use ONLY grid trailing stop (not profit target)
      // Profit target only applies when hedge is triggered
      if(CheckGridTrailingStop())
      {
         RequestCloseAll(false);

         Dashboard();

         return;
      }
   }

   if(IsHedgeOpen())
   {
      Dashboard();

      return;
   }

   ManageGrid();

   double gridFloating =
   GetGridProfit();

   if(gridFloating <= BasketLossLimit)
   {
      CloseOnlyGridPositions();

      if(IsHedgeOpen())
      {
         lossLimitHitWaitingForHedge = true;
      }
      else
      {
         PauseTradingUntil =
         TimeCurrent()
         + (RestartAfterHours * 3600);
      }
   }

   Dashboard();
}
