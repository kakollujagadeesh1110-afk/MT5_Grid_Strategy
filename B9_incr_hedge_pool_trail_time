//+------------------------------------------------------------------+
//| TOTAL PROFIT (Floating P/L of all open positions)                |
//+------------------------------------------------------------------+
double GetTotalProfit()
{
   double profit = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsOurPosition())
         continue;

      profit +=
      PositionGetDouble(POSITION_PROFIT);

      profit +=
      PositionGetDouble(POSITION_SWAP);
   }

   return profit;
}

