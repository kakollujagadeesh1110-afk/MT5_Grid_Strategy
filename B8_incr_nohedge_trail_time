//+------------------------------------------------------------------+
//|            XAUUSD GRID ENGINE (NO HEDGE) + TIME FILTER           |
//|         VERSION 6: INCREMENTAL GRID - NO HEDGE - TIME FILTERED   |
//|         - Incremental grid distance (200×N)                      |
//|         - NO hedging - pure grid                                 |
//|         - Grid trailing stop for profit                          |
//|         - Stop loss at $150 closes all                           |
//|         - DUAL WINDOW: Early London + Overlap (skips gap)        |
//|         - DAY FILTER: Monday/Friday restrictions                 |
//|         - MANUAL PAUSE: Via global variables (F3 in MT5)         |
//|         - AUTO DST HANDLING: Works with MT5 broker time          |
//+------------------------------------------------------------------+
#property strict

#include <Trade/Trade.mqh>
CTrade trade;

//========================= INPUTS ==================================//

input ulong  MagicNumber              = 26052508;

//---------------- GRID ----------------//

input double LotSize                  = 0.02;
input int    GridIncrementStep        = 200;    // V4: Base increment (distance = Step × GridCount)
input int    MaxTrades                = 50;

//---------------- BASKET --------------//

input double BasketProfit             = 10.0;
input double BasketStopLoss           = -150.0; // V4b: Stop loss - closes all at this loss

input int    RestartAfterHours        = 2;

//---------------- GRID TRAILING STOP ----------------//

input double GridTrailStart           = 20.0;   // Start trailing after this profit
input double GridTrailStep            = 10.0;   // Close if profit drops this much from peak

//---------------- TIME FILTER (V6) ----------------//
// MT5 shows US time (EST/EDT) - DST handled automatically by broker
// All times remain same year-round - no manual DST adjustment needed!

enum ENUM_TRADING_MODE
{
   MODE_DUAL_WINDOW,      // Early London (3:00-7:30) + Overlap (9:30-11:30) - SKIPS GAP (DEFAULT)
   MODE_OVERLAP_ONLY,     // London-NY Overlap: 9:30-11:30 AM (BEST for no-hedge, conservative)
   MODE_FULL_LONDON,      // Full London: 3:00 AM-11:30 AM (Continuous, includes gap)
   MODE_PEAK_HOUR,        // Peak Hour: 9:30-10:30 AM (Ultra-conservative)
   MODE_CUSTOM            // Custom: Set your own hours below
};

input bool   EnableTimeFilter         = true;   // Enable trading time restrictions
input ENUM_TRADING_MODE TradingMode   = MODE_DUAL_WINDOW; // Trading window preset (V6: DEFAULT = Dual Window)

// Custom time settings (only used if TradingMode = MODE_CUSTOM)
input int    CustomStartHour          = 9;      // Custom start hour (US time in MT5)
input int    CustomStartMinute        = 30;     // Custom start minute
input int    CustomEndHour            = 11;     // Custom end hour (US time in MT5)
input int    CustomEndMinute          = 30;     // Custom end minute

input bool   ClosePositionsOutsideHours = false; // Close all if outside trading hours

// NOTE: MT5 broker time shows US Eastern (EST/EDT) automatically adjusted for DST
// Because MT5 shows US time, settings work year-round:
//   Summer (EDT): London 8am = 3:00 AM EDT, London close = 11:30 AM EDT
//   Winter (EST): London 8am = 3:00 AM EST, London close = 11:30 AM EST
// Result: Same MT5 time settings work for both summer and winter!

//---------------- DAY FILTER (V6) ----------------//

input bool   EnableDayFilter          = true;   // Enable day-of-week restrictions

// Monday Settings (avoid early trading after weekend gap)
input bool   SkipMondayEarly          = true;   // Skip Monday before this hour
input int    MondayStartHour          = 15;     // Monday start at 3:00 PM US time (after gap settlement)

// Friday Settings (avoid late trading before weekend)
input bool   StopFridayLate           = true;   // Stop Friday after this hour
input int    FridayEndHour            = 21;     // Friday stop at 9:00 PM US time (before weekend risk)

//---------------- MANUAL PAUSE (V6) ----------------//
// Control trading manually via Global Variables (F3 in MT5)
// Global Variable Name: "B8_ManualPause"
//   Set to 0 = Resume Trading
//   Set to 1 = Pause Trading
// No need to restart EA - changes take effect immediately

string ManualPauseVarName = "B8_ManualPause";

//---------------- SAFETY --------------//

input double StopTradingBalance       = 1100.0;

input int    MaxSpreadPoints          = 80;

input double MinMarginLevel           = 250.0;

input int    TradeCooldownSeconds     = 3;

//========================= GLOBALS =================================//

int currentDirection = -1;

double gridPeakProfit = 0.0;

datetime PauseTradingUntil = 0;

datetime lastTradeTime = 0;

bool closeAllPending = false;
bool closeAfterLoss  = false;

//+------------------------------------------------------------------+
//| INIT                                                             |
//+------------------------------------------------------------------+
