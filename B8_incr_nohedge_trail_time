         Print("  SATURDAY:  NO TRADING (Market closes before windows)");
         Print("  SUNDAY:    NO TRADING (Market closed)");
         Print("  GAP SKIPPED: 15:30 - 17:30 UTC+3");
         Print("  WEEKLY:    ~32.5 hours (6.5 hrs × 5 days)");
      }
      else
      {
         int startHour, startMin, endHour, endMin;
         GetTradingHours(startHour, startMin, endHour, endMin);
