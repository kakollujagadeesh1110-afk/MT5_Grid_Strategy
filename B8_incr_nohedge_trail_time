//+------------------------------------------------------------------+
//|            XAUUSD GRID ENGINE (NO HEDGE) + TIME FILTER           |
//|         VERSION 7: INCREMENTAL GRID - NO HEDGE - TIME FILTERED   |
//|         - Incremental grid distance (200×N)                      |
//|         - NO hedging - pure grid                                 |
//|         - Grid trailing stop for profit                          |
//|         - Stop loss at $150 closes all                           |
//|         - CONSISTENT DUAL WINDOW (Mon-Fri same hours):           |
//|           * Window 1: 11:00-15:30 UTC+3 (Early London)           |
//|           * Window 2: 17:30-19:30 UTC+3 (London-NY Overlap)      |
//|           * Gap Skipped: 15:30-17:30 UTC+3                       |
//|           * Saturday/Sunday: NO TRADING                          |
//|         - Weekly Trading: ~32.5 hours (6.5 hrs × 5 days)         |
//|         - AUTO DST HANDLING: Works with MT5 broker time          |
//+------------------------------------------------------------------+
#property strict

#include <Trade/Trade.mqh>
CTrade trade;

//========================= INPUTS ==================================//

input ulong  MagicNumber              = 26052508;

//---------------- GRID ----------------//

input double LotSize                  = 0.02;
input int    GridIncrementStep        = 200;    // V4: Base increment (distance = Step × GridCount)
input int    MaxTrades                = 50;

//---------------- BASKET --------------//

input double BasketProfit             = 10.0;
input double BasketStopLoss           = -150.0; // V4b: Stop loss - closes all at this loss

input int    RestartAfterHours        = 2;

//---------------- GRID TRAILING STOP ----------------//

input double GridTrailStart           = 20.0;   // Start trailing after this profit
input double GridTrailStep            = 10.0;   // Close if profit drops this much from peak

//---------------- TIME FILTER (V6) ----------------//
// MT5 shows UTC+3 time - DST handled automatically by broker
// All times are in UTC+3 timezone

enum ENUM_TRADING_MODE
{
   MODE_DUAL_WINDOW,      // Early London (11:00-15:30) + Overlap (17:30-19:30) - SKIPS GAP (DEFAULT)
   MODE_OVERLAP_ONLY,     // London-NY Overlap: 17:30-19:30 (BEST for no-hedge, conservative)
   MODE_FULL_LONDON,      // Full London: 11:00-19:30 (Continuous, includes gap)
   MODE_PEAK_HOUR,        // Peak Hour: 17:30-18:30 (Ultra-conservative)
   MODE_CUSTOM            // Custom: Set your own hours below
};

input bool   EnableTimeFilter         = true;   // Enable trading time restrictions
input ENUM_TRADING_MODE TradingMode   = MODE_DUAL_WINDOW; // Trading window preset (V6: DEFAULT = Dual Window)

// Custom time settings (only used if TradingMode = MODE_CUSTOM)
input int    CustomStartHour          = 17;     // Custom start hour (UTC+3 time in MT5)
input int    CustomStartMinute        = 30;     // Custom start minute
input int    CustomEndHour            = 19;     // Custom end hour (UTC+3 time in MT5)
input int    CustomEndMinute          = 30;     // Custom end minute

input bool   ClosePositionsOutsideHours = false; // Close all if outside trading hours

// NOTE: MT5 broker time shows UTC+3 automatically adjusted for DST
// All trading times are in UTC+3 timezone
// Market sessions in UTC+3:
//   Early London: 11:00-15:30 UTC+3
//   Gap period: 15:30-17:30 UTC+3 (lower quality, skipped in DUAL_WINDOW mode)
//   London-NY Overlap: 17:30-19:30 UTC+3 (highest volatility)

//---------------- DAY FILTER (V7) ----------------//
// Consistent schedule: Same trading hours Mon-Fri
// Saturday/Sunday: No trading (market closed/closing)

input bool   EnableDayFilter          = true;   // Enable day-of-week restrictions

// V7: Simplified - No special Monday/Saturday windows
// Monday-Friday: Standard dual window (11:00-15:30 + 17:30-19:30)
// Saturday: No trading (market closes at 01:00 UTC+3, before our windows)
// Sunday: No trading (market closed)

//---------------- SAFETY --------------//

input double StopTradingBalance       = 1100.0;

input int    MaxSpreadPoints          = 80;

input double MinMarginLevel           = 250.0;

input int    TradeCooldownSeconds     = 3;

//========================= GLOBALS =================================//

int currentDirection = -1;

double gridPeakProfit = 0.0;

datetime PauseTradingUntil = 0;

datetime lastTradeTime = 0;

bool closeAllPending = false;
bool closeAfterLoss  = false;

//+------------------------------------------------------------------+
//| INIT                                                             |
//+------------------------------------------------------------------+
