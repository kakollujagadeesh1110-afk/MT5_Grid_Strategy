{
   trade.SetExpertMagicNumber(MagicNumber);

   trade.SetDeviationInPoints(20);

   trade.SetTypeFillingBySymbol(_Symbol);

   // V6: Initialize manual pause global variable if it doesn't exist
   if(!GlobalVariableCheck(ManualPauseVarName))
   {
      GlobalVariableSet(ManualPauseVarName, 0);  // 0 = Not paused (trading allowed)
      Print("Created global variable: ", ManualPauseVarName, " = 0 (Trading)");
   }

   Print("========================================");
   Print("     GRID V6 INITIALIZATION");
   Print("========================================");

   // Display time filter status
   if(EnableTimeFilter)
   {
      string modeName;
      switch(TradingMode)
      {
         case MODE_DUAL_WINDOW: modeName = "Dual Window (3:00-7:30 + 9:30-11:30)"; break;
         case MODE_OVERLAP_ONLY: modeName = "London-NY Overlap (9:30-11:30)"; break;
         case MODE_FULL_LONDON: modeName = "Full London Session (3:00-11:30)"; break;
         case MODE_PEAK_HOUR: modeName = "Peak Hour Only (9:30-10:30)"; break;
         case MODE_CUSTOM: modeName = "Custom Hours"; break;
         default: modeName = "Unknown"; break;
      }

      Print("=== TIME FILTER: ENABLED ===");
      Print("Trading Mode: ", modeName);

      if(TradingMode == MODE_DUAL_WINDOW)
      {
         Print("  Window 1: 03:00 - 07:30 (Early London)");
         Print("  Window 2: 09:30 - 11:30 (London-NY Overlap)");
         Print("  GAP SKIPPED: 07:30 - 09:30 (No trading)");
      }
      else
      {
         int startHour, startMin, endHour, endMin;
         GetTradingHours(startHour, startMin, endHour, endMin);
         Print("  Window: ", IntegerToString(startHour, 2, '0'), ":", IntegerToString(startMin, 2, '0'),
               " - ", IntegerToString(endHour, 2, '0'), ":", IntegerToString(endMin, 2, '0'));
      }

      Print("  Close outside hours: ", ClosePositionsOutsideHours ? "YES" : "NO");
   }
   else
   {
      Print("=== TIME FILTER: DISABLED ===");
      Print("Trading 24/7 (not recommended)");
   }

   // Display day filter status
   if(EnableDayFilter)
   {
      Print("=== DAY FILTER: ENABLED ===");
      if(SkipMondayEarly)
         Print("  Monday: Skip until ", IntegerToString(MondayStartHour, 2, '0'), ":00");
      if(StopFridayLate)
         Print("  Friday: Stop after ", IntegerToString(FridayEndHour, 2, '0'), ":00");
      Print("  Best Days: Tuesday-Thursday");
   }
   else
   {
      Print("=== DAY FILTER: DISABLED ===");
   }

   // Display manual pause control
   Print("=== MANUAL CONTROL ===");
   Print("Global Variable: ", ManualPauseVarName);
   Print("  Press F3 in MT5 to open Global Variables");
   Print("  Set ", ManualPauseVarName, " = 1 to PAUSE");
   Print("  Set ", ManualPauseVarName, " = 0 to RESUME");

   Print("========================================");
   Print("NOTE: DST automatically handled by MT5");
   Print("      Same settings work year-round!");
   Print("========================================");

   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| V6: GET TRADING HOURS BASED ON MODE                              |
//+------------------------------------------------------------------+
void GetTradingHours(int &startHour, int &startMin, int &endHour, int &endMin)
{
   switch(TradingMode)
   {
      case MODE_DUAL_WINDOW:
         // For dual window, return Window 1 times
         // (Window 2 is checked separately in IsWithinTradingHours)
         startHour = 3;
         startMin = 0;
         endHour = 7;
         endMin = 30;
         break;

      case MODE_OVERLAP_ONLY:
         startHour = 9;
         startMin = 30;
         endHour = 11;
         endMin = 30;
         break;

      case MODE_FULL_LONDON:
         startHour = 3;
         startMin = 0;
         endHour = 11;
         endMin = 30;
         break;

      case MODE_PEAK_HOUR:
         startHour = 9;
         startMin = 30;
         endHour = 10;
         endMin = 30;
         break;

      case MODE_CUSTOM:
         startHour = CustomStartHour;
         startMin = CustomStartMinute;
         endHour = CustomEndHour;
         endMin = CustomEndMinute;
         break;

      default:
         // Default to dual window
         startHour = 3;
         startMin = 0;
         endHour = 7;
         endMin = 30;
         break;
   }
}

//+------------------------------------------------------------------+
//| V6: CHECK IF WITHIN TRADING HOURS                                |
//| MT5 broker time shows US time (EST/EDT) with auto DST handling  |
//| Works for both summer (EDT) and winter (EST) automatically!     |
//| V6: Handles dual window mode (2 separate windows with gap)      |
//+------------------------------------------------------------------+
bool IsWithinTradingHours()
{
   if(!EnableTimeFilter)
      return true;  // No filter, always allow trading

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   int currentMinutes = dt.hour * 60 + dt.min;

   // V6: Special handling for MODE_DUAL_WINDOW
   if(TradingMode == MODE_DUAL_WINDOW)
   {
      // Window 1: 3:00 AM - 7:30 AM (Early London)
      int window1Start = 3 * 60 + 0;    // 180 minutes
      int window1End = 7 * 60 + 30;      // 450 minutes

      // Window 2: 9:30 AM - 11:30 AM (London-NY Overlap)
      int window2Start = 9 * 60 + 30;    // 570 minutes
      int window2End = 11 * 60 + 30;     // 690 minutes

      // Check if in either window
      bool inWindow1 = (currentMinutes >= window1Start) && (currentMinutes <= window1End);
      bool inWindow2 = (currentMinutes >= window2Start) && (currentMinutes <= window2End);

      return inWindow1 || inWindow2;
   }

   // For all other modes, use single window check
   int startHour, startMin, endHour, endMin;
   GetTradingHours(startHour, startMin, endHour, endMin);

   int startMinutes = startHour * 60 + startMin;
   int endMinutes = endHour * 60 + endMin;

   // Handle case where end time is past midnight (crosses day boundary)
   if(endMinutes < startMinutes)
   {
      // e.g., 22:00 to 02:00 next day
      return (currentMinutes >= startMinutes) || (currentMinutes <= endMinutes);
   }
   else
   {
      // Normal case: 3:00 to 11:30 or 9:30 to 11:30
      return (currentMinutes >= startMinutes) && (currentMinutes <= endMinutes);
   }
}

//+------------------------------------------------------------------+
//| V6: CHECK DAY-OF-WEEK FILTER                                     |
//| Returns true if trading allowed based on day/time restrictions  |
//+------------------------------------------------------------------+
bool IsTradingDayAllowed()
{
   if(!EnableDayFilter)
      return true;  // No day filter, always allow

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   // dt.day_of_week: 0=Sunday, 1=Monday, 2=Tuesday, ..., 6=Saturday

   // Monday restrictions
   if(dt.day_of_week == 1 && SkipMondayEarly)
   {
      // It's Monday, check if before allowed start hour
      if(dt.hour < MondayStartHour)
         return false;  // Too early on Monday
   }

   // Friday restrictions
   if(dt.day_of_week == 5 && StopFridayLate)
   {
      // It's Friday, check if after stop hour
      if(dt.hour >= FridayEndHour)
         return false;  // Too late on Friday
   }

   // Weekend (should not happen with XAUUSD, but check anyway)
   if(dt.day_of_week == 0 || dt.day_of_week == 6)
      return false;  // No trading on weekends

   return true;  // All checks passed
}

//+------------------------------------------------------------------+
//| V6: CHECK MANUAL PAUSE STATUS                                    |
//| Returns true if manually paused via global variable             |
//+------------------------------------------------------------------+
bool IsManuallyPaused()
{
   if(!GlobalVariableCheck(ManualPauseVarName))
   {
      // Variable doesn't exist, create it (not paused)
      GlobalVariableSet(ManualPauseVarName, 0);
      return false;
   }

   double value = GlobalVariableGet(ManualPauseVarName);
   return (value == 1.0);  // 1 = Paused, 0 = Not paused
}

//+------------------------------------------------------------------+
//| NORMALIZE LOT                                                    |
//+------------------------------------------------------------------+
double NormalizeLot(double lot)
{
   double minLot =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MIN);

   double maxLot =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MAX);

   double step =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_STEP);

   if(lot < minLot)
      lot = minLot;

   if(lot > maxLot)
      lot = maxLot;

   lot =
   MathFloor(lot / step) * step;

   return NormalizeDouble(lot,2);
}

//+------------------------------------------------------------------+
//| IS OUR POSITION                                                  |
//+------------------------------------------------------------------+
bool IsOurPosition()
{
   if(PositionGetString(POSITION_SYMBOL)
      != _Symbol)
      return false;

   if((ulong)PositionGetInteger(POSITION_MAGIC)
      != MagicNumber)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| IS GRID POSITION                                                 |
//+------------------------------------------------------------------+
bool IsGridPosition()
{
   if(!IsOurPosition())
      return false;

   string c =
   PositionGetString(POSITION_COMMENT);

   if(c == "GridBuy"
      || c == "GridSell")
      return true;

   return false;
}

//+------------------------------------------------------------------+
//| SPREAD CHECK                                                     |
//+------------------------------------------------------------------+
bool SpreadOK()
{
   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   double spread =
   (ask - bid) / _Point;

   if(spread > MaxSpreadPoints)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| MARGIN CHECK                                                     |
//+------------------------------------------------------------------+
bool MarginOK()
{
   double ml =
   AccountInfoDouble(ACCOUNT_MARGIN_LEVEL);

   if(ml <= 0)
      return true;

   if(ml < MinMarginLevel)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| ALLOW TRADING                                                    |
//+------------------------------------------------------------------+
bool AllowTrading()
{
   if(AccountInfoDouble(ACCOUNT_BALANCE)
      >= StopTradingBalance)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| COOLDOWN CHECK                                                   |
//+------------------------------------------------------------------+
bool CooldownOK()
{
   if(TimeCurrent() - lastTradeTime
      < TradeCooldownSeconds)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| TOTAL OUR POSITIONS                                              |
//+------------------------------------------------------------------+
int TotalOurPositions()
{
   int count = 0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(IsOurPosition())
         count++;
   }

   return count;
}

//+------------------------------------------------------------------+
//| COUNT GRID POSITIONS                                             |
//+------------------------------------------------------------------+
int CountGridPositions(int type)
{
   int count = 0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      if(PositionGetInteger(POSITION_TYPE)
         == type)
         count++;
   }

   return count;
}

//+------------------------------------------------------------------+
//| TOTAL GRID POSITIONS (both types)                                |
//+------------------------------------------------------------------+
int TotalGridPositions()
{
   int count = 0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(IsGridPosition())
         count++;
   }

   return count;
}

//+------------------------------------------------------------------+
//| GET GRID PROFIT                                                  |
//+------------------------------------------------------------------+
double GetGridProfit()
{
   double profit = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      profit +=
      PositionGetDouble(POSITION_PROFIT);

      profit +=
      PositionGetDouble(POSITION_SWAP);
   }

   return profit;
}

//+------------------------------------------------------------------+
//| OUTERMOST GRID PRICE                                             |
//+------------------------------------------------------------------+
double GetOuterGridPrice(int type)
{
   bool found = false;

   double price = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      if(PositionGetInteger(POSITION_TYPE)
         != type)
         continue;

      double p =
      PositionGetDouble(POSITION_PRICE_OPEN);

      if(!found)
      {
         found = true;
         price = p;
      }
      else
      {
         if(type == POSITION_TYPE_BUY
            && p < price)
            price = p;

         if(type == POSITION_TYPE_SELL
            && p > price)
            price = p;
      }
   }

   return price;
}

//+------------------------------------------------------------------+
//| V4: GET INCREMENTAL GRID DISTANCE                                |
//| Distance = GridIncrementStep × CurrentGridCount                  |
//+------------------------------------------------------------------+
int GetIncrementalGridDistance()
{
   int gridCount = TotalGridPositions();

   if(gridCount == 0)
      gridCount = 1;

   return GridIncrementStep * gridCount;
}

//+------------------------------------------------------------------+
//| RESET ENGINE                                                     |
//+------------------------------------------------------------------+
void ResetEngine()
{
   gridPeakProfit = 0.0;
}

//+------------------------------------------------------------------+
//| V4: MANAGE GRID WITH INCREMENTAL DISTANCE                        |
//+------------------------------------------------------------------+
void ManageGrid()
{
   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   if(!CooldownOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   // V4: Get incremental distance based on current grid count
   int requiredDistance = GetIncrementalGridDistance();

   // BUY GRID

   if(currentDirection == 0)
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_BUY
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_BUY
      );

      double distance =
      (outer - bid) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Buy(
            NormalizeLot(LotSize),
            _Symbol,
            ask,
            0,
            0,
            "GridBuy"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }

   // SELL GRID

   else
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_SELL
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_SELL
      );

      double distance =
      (ask - outer) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Sell(
            NormalizeLot(LotSize),
            _Symbol,
            bid,
            0,
            0,
            "GridSell"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }
}

//+------------------------------------------------------------------+
//| OPEN FIRST TRADE                                                 |
//+------------------------------------------------------------------+
void OpenFirstTrade()
{
   if(!AllowTrading())
      return;

   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   if(currentDirection == -1)
      currentDirection = 0;

   bool result = false;

   if(currentDirection == 0)
   {
      result =
      trade.Buy(
         NormalizeLot(LotSize),
         _Symbol,
         ask,
         0,
         0,
         "GridBuy"
      );
   }
   else
   {
      result =
      trade.Sell(
         NormalizeLot(LotSize),
         _Symbol,
         bid,
         0,
         0,
         "GridSell"
      );
   }

   if(result)
      lastTradeTime = TimeCurrent();
}

//+------------------------------------------------------------------+
//| REQUEST CLOSE ALL                                                |
//+------------------------------------------------------------------+
void RequestCloseAll(bool lossMode)
{
   closeAllPending = true;

   closeAfterLoss = lossMode;
}

//+------------------------------------------------------------------+
//| PROCESS CLOSE ALL                                                |
//+------------------------------------------------------------------+
void ProcessCloseAll()
{
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsOurPosition())
         continue;

      trade.PositionClose(ticket);
   }

   if(TotalOurPositions() == 0)
   {
      if(currentDirection == 0)
         currentDirection = 1;
      else
         currentDirection = 0;

      ResetEngine();

      if(closeAfterLoss)
      {
         PauseTradingUntil =
         TimeCurrent()
         + (RestartAfterHours * 3600);
      }

      closeAllPending = false;

      closeAfterLoss = false;
   }
}

//+------------------------------------------------------------------+
//| CHECK GRID TRAILING STOP                                         |
//+------------------------------------------------------------------+
bool CheckGridTrailingStop()
{
   double gridProfit = GetGridProfit();

   if(gridProfit > gridPeakProfit)
      gridPeakProfit = gridProfit;

   if(gridPeakProfit >= GridTrailStart)
   {
      double trailLevel = gridPeakProfit - GridTrailStep;

      if(gridProfit <= trailLevel)
         return true;
   }

   return false;
}

//+------------------------------------------------------------------+
//| DASHBOARD                                                        |
//+------------------------------------------------------------------+
void Dashboard()
{
   double gridProfit =
   GetGridProfit();

   int gridCount = TotalGridPositions();
   int nextDistance = GetIncrementalGridDistance();

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   string currentTime = StringFormat("%02d:%02d:%02d", dt.hour, dt.min, dt.sec);

   bool withinHours = IsWithinTradingHours();
   bool dayAllowed = IsTradingDayAllowed();
   bool manualPause = IsManuallyPaused();

   string modeName;
   switch(TradingMode)
   {
      case MODE_DUAL_WINDOW: modeName = "Dual Window"; break;
      case MODE_OVERLAP_ONLY: modeName = "Overlap Only"; break;
      case MODE_FULL_LONDON: modeName = "Full London"; break;
      case MODE_PEAK_HOUR: modeName = "Peak Hour"; break;
      case MODE_CUSTOM: modeName = "Custom"; break;
      default: modeName = "Unknown"; break;
   }

   // Determine current window for DUAL_WINDOW mode
   string currentWindow = "";
   if(TradingMode == MODE_DUAL_WINDOW && withinHours)
   {
      int currentMinutes = dt.hour * 60 + dt.min;
      if(currentMinutes >= 180 && currentMinutes <= 450)
         currentWindow = "Window 1 (Early London)";
      else if(currentMinutes >= 570 && currentMinutes <= 690)
         currentWindow = "Window 2 (Overlap)";
   }

   // Day name
   string dayName;
   switch(dt.day_of_week)
   {
      case 0: dayName = "Sunday"; break;
      case 1: dayName = "Monday"; break;
      case 2: dayName = "Tuesday"; break;
      case 3: dayName = "Wednesday"; break;
      case 4: dayName = "Thursday"; break;
      case 5: dayName = "Friday"; break;
      case 6: dayName = "Saturday"; break;
      default: dayName = "Unknown"; break;
   }

   // Build strings beforehand to avoid Comment() parameter count issues
   string windowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW)
      windowInfo = "\nWindow 1: 03:00-07:30 (Early London)\nWindow 2: 09:30-11:30 (Overlap)\nGAP SKIPPED: 07:30-09:30";

   string currentWindowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW && currentWindow != "")
      currentWindowInfo = "\nCurrent Window: " + currentWindow;

   string dayBestTag = "";
   if(dt.day_of_week >= 2 && dt.day_of_week <= 4)
      dayBestTag = " (BEST DAY)";

   string dayStatusInfo = "";
   if(EnableDayFilter)
      dayStatusInfo = "\nDay Status: " + (dayAllowed ? "ALLOWED" : "RESTRICTED");

   string mondayInfo = "";
   if(dt.day_of_week == 1 && SkipMondayEarly)
      mondayInfo = StringFormat("\nMonday Skip: Before %02d:00", MondayStartHour);

   string fridayInfo = "";
   if(dt.day_of_week == 5 && StopFridayLate)
      fridayInfo = StringFormat("\nFriday Stop: After %02d:00", FridayEndHour);

   string pauseAction = manualPause ? "\nSet to 0 to RESUME trading" : "\nSet to 1 to PAUSE trading";

   string blockReasons = "";
   if(!withinHours) blockReasons += "\n  >> OUTSIDE TIME WINDOW";
   if(!dayAllowed) blockReasons += "\n  >> DAY RESTRICTED";
   if(manualPause) blockReasons += "\n  >> MANUALLY PAUSED";

   Comment(
      "GRID V6 (Incremental + NO HEDGE + DUAL WINDOW + DAY FILTER)\n",
      "\n--- TIME FILTER ---",
      "\nTime Filter: ", EnableTimeFilter ? "ENABLED" : "DISABLED",
      "\nTrading Mode: ", modeName,
      windowInfo,
      "\nCurrent Time (MT5): ", currentTime, " (US EST/EDT)",
      currentWindowInfo,
      "\nTime Status: ", withinHours ? "INSIDE WINDOW" : "OUTSIDE WINDOW",

      "\n--- DAY FILTER ---",
      "\nDay Filter: ", EnableDayFilter ? "ENABLED" : "DISABLED",
      "\nToday: ", dayName, dayBestTag,
      dayStatusInfo,
      mondayInfo,
      fridayInfo,

      "\n--- MANUAL CONTROL ---",
      "\nManual Pause: ", manualPause ? "ON (PAUSED)" : "OFF",
      "\nControl: Press F3 > ", ManualPauseVarName,
      pauseAction,

      "\n--- TRADING STATUS ---",
      "\nOverall Status: ", (withinHours && dayAllowed && !manualPause) ? "TRADING ALLOWED" : "TRADING BLOCKED",
      blockReasons,

      "\n\n--- INCREMENTAL GRID ---",

      "\nGrid Positions: ",
      IntegerToString(gridCount),

      "\nNext Grid Distance: ",
      IntegerToString(nextDistance),
      " pts",

      "\nIncrement Step: ",
      IntegerToString(GridIncrementStep),

      "\n\n--- PROFIT/LOSS ---",

      "\nGrid Floating P/L: ",
      DoubleToString(gridProfit,2),

      "\n\n--- TRAILING STOP ---",

      "\nGrid Peak Profit: ",
      DoubleToString(gridPeakProfit,2),

      "\nTrail Start: ",
      DoubleToString(GridTrailStart,2),

      "\nTrail Step: ",
      DoubleToString(GridTrailStep,2),

      "\nTrail Level: ",
      (gridPeakProfit >= GridTrailStart)
      ? DoubleToString(gridPeakProfit - GridTrailStep,2)
      : "Not Active",

      "\n\n--- TARGETS ---",

      "\nProfit Target: ",
      DoubleToString(BasketProfit,2),

      "\nStop Loss: ",
      DoubleToString(BasketStopLoss,2),

      "\n\n--- DIRECTION ---",

      "\nGrid Direction: ",
      (currentDirection == 0)
      ? "BUY"
      : "SELL",

      "\nLoss Pause: ",
      (PauseTradingUntil > 0 && TimeCurrent() < PauseTradingUntil)
      ? "YES (After Stop Loss)"
      : "NO",

      "\n\nNOTE: DST auto-handled by MT5 broker time"
   );
}

