   trade.SetDeviationInPoints(20);

   trade.SetTypeFillingBySymbol(_Symbol);

   Print("========================================");
   Print("     GRID V6 INITIALIZATION");
   Print("========================================");

   // Display time filter status
   if(EnableTimeFilter)
   {
      string modeName;
      switch(TradingMode)
      {
         case MODE_DUAL_WINDOW: modeName = "Dual Window (11:00-15:30 + 17:30-19:30)"; break;
         case MODE_OVERLAP_ONLY: modeName = "London-NY Overlap (17:30-19:30)"; break;
         case MODE_FULL_LONDON: modeName = "Full London Session (11:00-19:30)"; break;
         case MODE_PEAK_HOUR: modeName = "Peak Hour Only (17:30-18:30)"; break;
         case MODE_CUSTOM: modeName = "Custom Hours"; break;
         default: modeName = "Unknown"; break;
      }

