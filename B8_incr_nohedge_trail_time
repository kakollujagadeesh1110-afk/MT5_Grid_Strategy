//+------------------------------------------------------------------+
//| V6: GET TRADING HOURS BASED ON MODE                              |
//+------------------------------------------------------------------+
void GetTradingHours(int &startHour, int &startMin, int &endHour, int &endMin)
{
   switch(TradingMode)
   {
      case MODE_DUAL_WINDOW:
         // For dual window, return Window 1 times
         // (Window 2 is checked separately in IsWithinTradingHours)
         startHour = 11;
         startMin = 0;
         endHour = 15;
         endMin = 30;
         break;

      case MODE_OVERLAP_ONLY:
         startHour = 17;
         startMin = 30;
         endHour = 19;
         endMin = 30;
         break;

      case MODE_FULL_LONDON:
         startHour = 11;
         startMin = 0;
         endHour = 19;
         endMin = 30;
         break;

      case MODE_PEAK_HOUR:
         startHour = 17;
         startMin = 30;
         endHour = 18;
         endMin = 30;
         break;

      case MODE_CUSTOM:
         startHour = CustomStartHour;
         startMin = CustomStartMinute;
         endHour = CustomEndHour;
         endMin = CustomEndMinute;
         break;

      default:
         // Default to dual window
         startHour = 11;
         startMin = 0;
         endHour = 15;
         endMin = 30;
         break;
   }
}

//+------------------------------------------------------------------+
//| V7: CHECK IF WITHIN TRADING HOURS                                |
//| MT5 broker time shows UTC+3 with auto DST handling               |
//| V7: Consistent dual window - same hours Monday through Friday    |
//+------------------------------------------------------------------+
bool IsWithinTradingHours()
{
   if(!EnableTimeFilter)
      return true;  // No filter, always allow trading

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   int currentMinutes = dt.hour * 60 + dt.min;

   // V7: MODE_DUAL_WINDOW - Same windows for all trading days (Mon-Fri)
   if(TradingMode == MODE_DUAL_WINDOW)
   {
      // Window 1: 11:00 - 15:30 (Early London)
      int window1Start = 11 * 60 + 0;    // 660 minutes
      int window1End = 15 * 60 + 30;      // 930 minutes

      // Window 2: 17:30 - 19:30 (London-NY Overlap)
      int window2Start = 17 * 60 + 30;    // 1050 minutes
      int window2End = 19 * 60 + 30;     // 1170 minutes

      // Check if in either window
      bool inWindow1 = (currentMinutes >= window1Start) && (currentMinutes <= window1End);
      bool inWindow2 = (currentMinutes >= window2Start) && (currentMinutes <= window2End);

      return inWindow1 || inWindow2;
   }

   // For all other modes, use single window check
   int startHour, startMin, endHour, endMin;
   GetTradingHours(startHour, startMin, endHour, endMin);

   int startMinutes = startHour * 60 + startMin;
   int endMinutes = endHour * 60 + endMin;

   // Handle case where end time is past midnight (crosses day boundary)
   if(endMinutes < startMinutes)
   {
      // e.g., 22:00 to 02:00 next day
      return (currentMinutes >= startMinutes) || (currentMinutes <= endMinutes);
   }
   else
   {
      // Normal case: 3:00 to 11:30 or 9:30 to 11:30
      return (currentMinutes >= startMinutes) && (currentMinutes <= endMinutes);
   }
}

//+------------------------------------------------------------------+
//| V7: CHECK DAY-OF-WEEK FILTER                                     |
//| Returns true if trading allowed based on day restrictions        |
//| V7: Simplified - Block Saturday/Sunday, allow Monday-Friday      |
//+------------------------------------------------------------------+
bool IsTradingDayAllowed()
{
   if(!EnableDayFilter)
      return true;  // No day filter, always allow

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   // dt.day_of_week: 0=Sunday, 1=Monday, 2=Tuesday, ..., 6=Saturday

   // Sunday - no trading (market closed)
   if(dt.day_of_week == 0)
      return false;

   // Saturday - no trading (market closes at 01:00 UTC+3, before our windows start at 11:00)
   if(dt.day_of_week == 6)
      return false;

   // Monday-Friday: Allow (time windows handled by IsWithinTradingHours)
   return true;
}

//+------------------------------------------------------------------+
//| NORMALIZE LOT                                                    |
//+------------------------------------------------------------------+
double NormalizeLot(double lot)
{
   double minLot =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MIN);

   double maxLot =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MAX);

   double step =
   SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_STEP);

   if(lot < minLot)
      lot = minLot;

   if(lot > maxLot)
      lot = maxLot;

   lot =
   MathFloor(lot / step) * step;

   return NormalizeDouble(lot,2);
}

//+------------------------------------------------------------------+
//| IS OUR POSITION                                                  |
//+------------------------------------------------------------------+
bool IsOurPosition()
{
   if(PositionGetString(POSITION_SYMBOL)
      != _Symbol)
      return false;

   if((ulong)PositionGetInteger(POSITION_MAGIC)
      != MagicNumber)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| IS GRID POSITION                                                 |
//+------------------------------------------------------------------+
bool IsGridPosition()
{
   if(!IsOurPosition())
      return false;

   string c =
   PositionGetString(POSITION_COMMENT);

   if(c == "GridBuy"
      || c == "GridSell")
      return true;

   return false;
}

//+------------------------------------------------------------------+
//| SPREAD CHECK                                                     |
//+------------------------------------------------------------------+
bool SpreadOK()
{
   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   double spread =
   (ask - bid) / _Point;

   if(spread > MaxSpreadPoints)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| MARGIN CHECK                                                     |
//+------------------------------------------------------------------+
bool MarginOK()
{
   double ml =
   AccountInfoDouble(ACCOUNT_MARGIN_LEVEL);

   if(ml <= 0)
      return true;

   if(ml < MinMarginLevel)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| ALLOW TRADING                                                    |
//+------------------------------------------------------------------+
bool AllowTrading()
{
   if(AccountInfoDouble(ACCOUNT_BALANCE)
      >= StopTradingBalance)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| COOLDOWN CHECK                                                   |
//+------------------------------------------------------------------+
bool CooldownOK()
{
   if(TimeCurrent() - lastTradeTime
      < TradeCooldownSeconds)
      return false;

   return true;
}

//+------------------------------------------------------------------+
//| TOTAL OUR POSITIONS                                              |
//+------------------------------------------------------------------+
int TotalOurPositions()
{
   int count = 0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(IsOurPosition())
         count++;
   }

   return count;
}

//+------------------------------------------------------------------+
//| COUNT GRID POSITIONS                                             |
//+------------------------------------------------------------------+
int CountGridPositions(int type)
{
   int count = 0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      if(PositionGetInteger(POSITION_TYPE)
         == type)
         count++;
   }

   return count;
}

//+------------------------------------------------------------------+
//| TOTAL GRID POSITIONS (both types)                                |
//+------------------------------------------------------------------+
int TotalGridPositions()
{
   int count = 0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(IsGridPosition())
         count++;
   }

   return count;
}

//+------------------------------------------------------------------+
//| GET GRID PROFIT                                                  |
//+------------------------------------------------------------------+
double GetGridProfit()
{
   double profit = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      profit +=
      PositionGetDouble(POSITION_PROFIT);

      profit +=
      PositionGetDouble(POSITION_SWAP);
   }

   return profit;
}

//+------------------------------------------------------------------+
//| OUTERMOST GRID PRICE                                             |
//+------------------------------------------------------------------+
double GetOuterGridPrice(int type)
{
   bool found = false;

   double price = 0.0;

   for(int i=0;i<PositionsTotal();i++)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsGridPosition())
         continue;

      if(PositionGetInteger(POSITION_TYPE)
         != type)
         continue;

      double p =
      PositionGetDouble(POSITION_PRICE_OPEN);

      if(!found)
      {
         found = true;
         price = p;
      }
      else
      {
         if(type == POSITION_TYPE_BUY
            && p < price)
            price = p;

         if(type == POSITION_TYPE_SELL
            && p > price)
            price = p;
      }
   }

   return price;
}

//+------------------------------------------------------------------+
//| V4: GET INCREMENTAL GRID DISTANCE                                |
//| Distance = GridIncrementStep × CurrentGridCount                  |
//+------------------------------------------------------------------+
int GetIncrementalGridDistance()
{
   int gridCount = TotalGridPositions();

   if(gridCount == 0)
      gridCount = 1;

   return GridIncrementStep * gridCount;
}

//+------------------------------------------------------------------+
//| RESET ENGINE                                                     |
//+------------------------------------------------------------------+
void ResetEngine()
{
   gridPeakProfit = 0.0;
}

//+------------------------------------------------------------------+
//| V4: MANAGE GRID WITH INCREMENTAL DISTANCE                        |
//+------------------------------------------------------------------+
void ManageGrid()
{
   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   if(!CooldownOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   // V4: Get incremental distance based on current grid count
   int requiredDistance = GetIncrementalGridDistance();

   // BUY GRID

   if(currentDirection == 0)
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_BUY
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_BUY
      );

      double distance =
      (outer - bid) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Buy(
            NormalizeLot(LotSize),
            _Symbol,
            ask,
            0,
            0,
            "GridBuy"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }

   // SELL GRID

   else
   {
      int count =
      CountGridPositions(
         POSITION_TYPE_SELL
      );

      if(count >= MaxTrades)
         return;

      double outer =
      GetOuterGridPrice(
         POSITION_TYPE_SELL
      );

      double distance =
      (ask - outer) / _Point;

      // V4: Use incremental distance
      if(distance >= requiredDistance)
      {
         bool result =
         trade.Sell(
            NormalizeLot(LotSize),
            _Symbol,
            bid,
            0,
            0,
            "GridSell"
         );

         if(result)
            lastTradeTime =
            TimeCurrent();
      }
   }
}

//+------------------------------------------------------------------+
//| OPEN FIRST TRADE                                                 |
//+------------------------------------------------------------------+
void OpenFirstTrade()
{
   if(!AllowTrading())
      return;

   if(!SpreadOK())
      return;

   if(!MarginOK())
      return;

   double ask =
   SymbolInfoDouble(_Symbol,SYMBOL_ASK);

   double bid =
   SymbolInfoDouble(_Symbol,SYMBOL_BID);

   if(currentDirection == -1)
      currentDirection = 0;

   bool result = false;

   if(currentDirection == 0)
   {
      result =
      trade.Buy(
         NormalizeLot(LotSize),
         _Symbol,
         ask,
         0,
         0,
         "GridBuy"
      );
   }
   else
   {
      result =
      trade.Sell(
         NormalizeLot(LotSize),
         _Symbol,
         bid,
         0,
         0,
         "GridSell"
      );
   }

   if(result)
      lastTradeTime = TimeCurrent();
}

//+------------------------------------------------------------------+
//| REQUEST CLOSE ALL                                                |
//+------------------------------------------------------------------+
void RequestCloseAll(bool lossMode)
{
   closeAllPending = true;

   closeAfterLoss = lossMode;
}

//+------------------------------------------------------------------+
//| PROCESS CLOSE ALL                                                |
//+------------------------------------------------------------------+
void ProcessCloseAll()
{
   for(int i=PositionsTotal()-1;i>=0;i--)
   {
      ulong ticket =
      PositionGetTicket(i);

      if(!PositionSelectByTicket(ticket))
         continue;

      if(!IsOurPosition())
         continue;

      trade.PositionClose(ticket);
   }

   if(TotalOurPositions() == 0)
   {
      if(currentDirection == 0)
         currentDirection = 1;
      else
         currentDirection = 0;

      ResetEngine();

      if(closeAfterLoss)
      {
         PauseTradingUntil =
         TimeCurrent()
         + (RestartAfterHours * 3600);
      }

      closeAllPending = false;

      closeAfterLoss = false;
   }
}

//+------------------------------------------------------------------+
//| CHECK GRID TRAILING STOP                                         |
//+------------------------------------------------------------------+
bool CheckGridTrailingStop()
{
   double gridProfit = GetGridProfit();

   if(gridProfit > gridPeakProfit)
      gridPeakProfit = gridProfit;

   if(gridPeakProfit >= GridTrailStart)
   {
      double trailLevel = gridPeakProfit - GridTrailStep;

      if(gridProfit <= trailLevel)
         return true;
   }

   return false;
}

//+------------------------------------------------------------------+
//| DASHBOARD                                                        |
//+------------------------------------------------------------------+
void Dashboard()
{
   double gridProfit =
   GetGridProfit();

   int gridCount = TotalGridPositions();
   int nextDistance = GetIncrementalGridDistance();

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   string currentTime = StringFormat("%02d:%02d:%02d", dt.hour, dt.min, dt.sec);

   bool withinHours = IsWithinTradingHours();
   bool dayAllowed = IsTradingDayAllowed();

   string modeName;
   switch(TradingMode)
   {
      case MODE_DUAL_WINDOW: modeName = "Dual Window"; break;
      case MODE_OVERLAP_ONLY: modeName = "Overlap Only"; break;
      case MODE_FULL_LONDON: modeName = "Full London"; break;
      case MODE_PEAK_HOUR: modeName = "Peak Hour"; break;
      case MODE_CUSTOM: modeName = "Custom"; break;
      default: modeName = "Unknown"; break;
   }

   // Determine current window for DUAL_WINDOW mode
   string currentWindow = "";
   if(TradingMode == MODE_DUAL_WINDOW && withinHours)
   {
      int currentMinutes = dt.hour * 60 + dt.min;
      if(currentMinutes >= 660 && currentMinutes <= 930)
         currentWindow = "Window 1 (Early London)";
      else if(currentMinutes >= 1050 && currentMinutes <= 1170)
         currentWindow = "Window 2 (Overlap)";
   }

   // Day name
   string dayName;
   switch(dt.day_of_week)
   {
      case 0: dayName = "Sunday"; break;
      case 1: dayName = "Monday"; break;
      case 2: dayName = "Tuesday"; break;
      case 3: dayName = "Wednesday"; break;
      case 4: dayName = "Thursday"; break;
      case 5: dayName = "Friday"; break;
      case 6: dayName = "Saturday"; break;
      default: dayName = "Unknown"; break;
   }

   // Build strings beforehand to avoid Comment() parameter count issues
   string windowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW)
   {
      if(dt.day_of_week == 0)  // Sunday
         windowInfo = "\nSUNDAY: NO TRADING (Market closed)";
      else if(dt.day_of_week == 6)  // Saturday
         windowInfo = "\nSATURDAY: NO TRADING (Market closes at 01:00)";
      else  // Monday-Friday
         windowInfo = "\nMON-FRI: Window 1: 11:00-15:30 UTC+3\nWindow 2: 17:30-19:30 UTC+3\nGAP SKIPPED: 15:30-17:30 UTC+3";
   }

   string currentWindowInfo = "";
   if(TradingMode == MODE_DUAL_WINDOW && currentWindow != "")
      currentWindowInfo = "\nCurrent Window: " + currentWindow;

   string dayBestTag = "";
   if(dt.day_of_week >= 2 && dt.day_of_week <= 4)
      dayBestTag = " (BEST DAY)";

   string dayStatusInfo = "";
   if(EnableDayFilter)
      dayStatusInfo = "\nDay Status: " + (dayAllowed ? "ALLOWED" : "NO TRADING");

   string blockReasons = "";
   if(!withinHours) blockReasons += "\n  >> OUTSIDE TIME WINDOW";
   if(!dayAllowed) blockReasons += "\n  >> DAY RESTRICTED";

   // Build complete dashboard incrementally to avoid expression limits
   string dashboard = "GRID V6 (Incremental + NO HEDGE + DUAL WINDOW + DAY FILTER)\n";

   dashboard += "\n--- TIME FILTER ---";
   dashboard += "\nTime Filter: " + (EnableTimeFilter ? "ENABLED" : "DISABLED");
   dashboard += "\nTrading Mode: " + modeName;
   dashboard += windowInfo;
   dashboard += "\nCurrent Time (MT5): " + currentTime + " (UTC+3)";
   dashboard += currentWindowInfo;
   dashboard += "\nTime Status: " + (withinHours ? "INSIDE WINDOW" : "OUTSIDE WINDOW");

   dashboard += "\n--- DAY FILTER ---";
   dashboard += "\nDay Filter: " + (EnableDayFilter ? "ENABLED" : "DISABLED");
   dashboard += "\nToday: " + dayName + dayBestTag;
   dashboard += dayStatusInfo;

   dashboard += "\n--- TRADING STATUS ---";
   dashboard += "\nOverall Status: " + ((withinHours && dayAllowed) ? "TRADING ALLOWED" : "TRADING BLOCKED");
   dashboard += blockReasons;

   dashboard += "\n\n--- INCREMENTAL GRID ---";
   dashboard += "\nGrid Positions: " + IntegerToString(gridCount);
   dashboard += "\nNext Grid Distance: " + IntegerToString(nextDistance) + " pts";
   dashboard += "\nIncrement Step: " + IntegerToString(GridIncrementStep);

   dashboard += "\n\n--- PROFIT/LOSS ---";
   dashboard += "\nGrid Floating P/L: " + DoubleToString(gridProfit,2);

   dashboard += "\n\n--- CLOSE MODE ---";
   bool trailingActive = (gridPeakProfit >= GridTrailStart);
   dashboard += "\nMode: " + (trailingActive ? "TRAILING STOP (letting profits run)" : "FIXED TARGET ($" + DoubleToString(BasketProfit,2) + ")");
   dashboard += "\nGrid Peak Profit: " + DoubleToString(gridPeakProfit,2);
   dashboard += "\nTrail Activates At: $" + DoubleToString(GridTrailStart,2);
   dashboard += "\nTrail Step: $" + DoubleToString(GridTrailStep,2);
   if(trailingActive)
      dashboard += "\nTrail Level: $" + DoubleToString(gridPeakProfit - GridTrailStep,2) + " (closes if profit drops here)";
   else
      dashboard += "\nTrail Level: Not Active (profit < $" + DoubleToString(GridTrailStart,2) + ")";

   dashboard += "\n\n--- TARGETS ---";
   dashboard += "\nProfit Target: " + DoubleToString(BasketProfit,2);
   dashboard += "\nStop Loss: " + DoubleToString(BasketStopLoss,2);

   dashboard += "\n\n--- DIRECTION ---";
   dashboard += "\nGrid Direction: " + ((currentDirection == 0) ? "BUY" : "SELL");
   dashboard += "\nLoss Pause: " + ((PauseTradingUntil > 0 && TimeCurrent() < PauseTradingUntil) ? "YES (After Stop Loss)" : "NO");

   dashboard += "\n\nNOTE: All times in UTC+3 timezone";

   Comment(dashboard);
}

//+------------------------------------------------------------------+
//| ON TICK                                                          |
//+------------------------------------------------------------------+
void OnTick()
{
   if(closeAllPending)
   {
      ProcessCloseAll();

      Dashboard();

      return;
   }

   if(PauseTradingUntil > 0
      && TimeCurrent() < PauseTradingUntil)
   {
      Dashboard();

      return;
   }

   // V6: DAY FILTER CHECK
   if(!IsTradingDayAllowed())
   {
      Dashboard();  // Show day restriction status
      return;        // Stop trading on restricted days/times
   }

   // V6: TIME FILTER CHECK
   if(!IsWithinTradingHours())
   {
      // If outside trading hours and we have positions
      if(ClosePositionsOutsideHours && TotalOurPositions() > 0)
      {
         RequestCloseAll(false);  // Close without pause

         Dashboard();

         return;
      }

      // Just show dashboard and wait
      Dashboard();

      return;
   }

   if(!AllowTrading())
   {
      Dashboard();

      return;
   }

   // NO POSITIONS

   if(TotalOurPositions() == 0)
   {
      OpenFirstTrade();

      Dashboard();

      return;
   }

   // CHECK PROFIT CLOSE CONDITIONS

   double gridProfit = GetGridProfit();

   // Update peak profit tracking
   if(gridProfit > gridPeakProfit)
      gridPeakProfit = gridProfit;

   // Determine if trailing stop mode is active
   bool trailingActive = (gridPeakProfit >= GridTrailStart);

   if(trailingActive)
   {
      // TRAILING MODE: Only close when profit drops GridTrailStep from peak
      double trailLevel = gridPeakProfit - GridTrailStep;

      if(gridProfit <= trailLevel)
      {
         Print("TRAILING STOP triggered: Peak=", gridPeakProfit, " Current=", gridProfit, " TrailLevel=", trailLevel);
         RequestCloseAll(false);

         Dashboard();

         return;
      }
      // In trailing mode, ignore fixed profit target - let profits run!
   }
   else
   {
      // NOT IN TRAILING MODE: Use fixed profit target
      if(gridProfit >= BasketProfit)
      {
         Print("FIXED TARGET reached: Profit=", gridProfit, " Target=", BasketProfit);
         RequestCloseAll(false);

         Dashboard();

         return;
      }
   }

   // CHECK STOP LOSS (V4b: $150 loss closes all)

   if(gridProfit <= BasketStopLoss)
   {
      RequestCloseAll(true);  // Close with loss mode (will pause)

      Dashboard();

      return;
   }

   // MANAGE GRID

   ManageGrid();

   Dashboard();
}
