   dash += "\nPositions: " + IntegerToString(gridCount);
   dash += "\nDirection: " + ((currentDirection == 0) ? "BUY" : "SELL");
   dash += "\nNext Distance: " + IntegerToString(GetIncrementalGridDistance()) + " pts";

   dash += "\n\n--- PROFIT/LOSS ---";
   dash += "\nGrid Floating P/L: $" + DoubleToString(gridProfit, 2);
   dash += "\nDay Net Profit: $" + DoubleToString(dayNetProfit, 2);

   dash += "\n\n--- TRAILING STOP (Dynamic) ---";
   dash += "\nPeak Profit: $" + DoubleToString(gridPeakProfit, 2);
   dash += "\nTrail Start: $" + DoubleToString(GridTrailStart, 2);
   dash += "\nDynamic Step: $" + DoubleToString(dynamicStep, 2) + " (Pos:" + IntegerToString(gridCount) + ")";
   dash += "\nMin Profit Floor: $" + DoubleToString(MinTrailProfit, 2);
   dash += "\nTrail Status: " + trailStatus;
   dash += "\nClose Level: " + trailLevelStr;

   dash += "\n\n--- DYNAMIC STOP LOSS (Scaled) ---";
   dash += "\nCurrent Stop Loss: $" + DoubleToString(currentStopLoss, 2);
   dash += "\nMin/Max SL: $" + DoubleToString(minSL, 2) + " / $" + DoubleToString(maxSL, 2);
   dash += "\nSL Threshold: $" + DoubleToString(slThreshold, 2);
   dash += "\nSL Cushion: $" + DoubleToString(GetScaledSLCushion(), 2);

   dash += "\n\n--- DAILY LIMITS ---";
