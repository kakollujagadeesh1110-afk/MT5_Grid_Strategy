      pauseStatus = "YES (" + IntegerToString(remainingSecs / 60) + "m " +
                    IntegerToString(remainingSecs % 60) + "s)";
   }

   string marketStatus = IsMarketOpen() ? "OPEN" : "CLOSED";
   string bufferStatus = IsInMarketPauseBuffer() ? "YES" : "NO";
   string dailyTargetStatus = IsDailyTargetReached() ? "REACHED!" : "Active";
   string dailyLossStatus = IsDailyLossLimitReached() ? "REACHED!" : "Active";

