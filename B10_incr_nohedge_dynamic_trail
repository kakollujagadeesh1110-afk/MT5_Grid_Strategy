   double lossThreshold1 = GetScaledLossThreshold1();
   double lossThreshold2 = GetScaledLossThreshold2();
   double reducedTarget1 = GetScaledReducedTarget1();
   double reducedTarget2 = GetScaledReducedTarget2();
