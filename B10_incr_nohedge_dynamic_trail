      targetReductionStatus = "LEVEL 2 (Loss >= $" + DoubleToString(lossThreshold2, 0) + ")";
   else if(targetReducedToLevel1)
      targetReductionStatus = "LEVEL 1 (Loss >= $" + DoubleToString(lossThreshold1, 0) + ")";

   string trailStatus = "Waiting";
   double dynamicStep = GetDynamicTrailStep();
   double trailCloseLevel = GetTrailCloseLevel();
   if(gridPeakProfit >= GridTrailStart)
   {
      trailStatus = "ACTIVE";
   }

   string trailLevelStr = (trailStatus == "ACTIVE") ? ("$" + DoubleToString(trailCloseLevel, 2)) : "N/A";
   string threshold1Hit = targetReducedToLevel1 ? " [HIT]" : "";
   string threshold2Hit = targetReducedToLevel2 ? " [HIT]" : "";

   // Build dashboard string
   string dash = "=== B10: INCREMENTAL GRID - DYNAMIC STOP LOSS ===\n";

   dash += "\n--- GRID STATUS ---";
