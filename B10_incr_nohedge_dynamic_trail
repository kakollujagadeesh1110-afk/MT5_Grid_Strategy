//+------------------------------------------------------------------+
//| EXPERT TICK FUNCTION                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   // Check for new day and reset counters
   CheckDayReset();

   // Check and update loss threshold flags (affects daily target)
   CheckLossThresholds();

   // Handle pending close operations
   if(closeAllPending)
   {
      ProcessCloseAll();
      Dashboard();
      return;
   }

   // Check if in dynamic pause (after stop loss)
   if(pauseUntil > 0 && TimeCurrent() < pauseUntil)
   {
      Dashboard();
      return;
   }

   // Get current positions
   int totalPositions = TotalOurPositions();

   // STEP 1: If we have active positions, ALWAYS manage them
   if(totalPositions > 0)
   {
      double gridProfit = GetGridProfit();

      // Update peak profit for trailing
      if(gridProfit > gridPeakProfit)
         gridPeakProfit = gridProfit;

      // Get current dynamic stop loss
      double currentStopLoss = GetDynamicStopLoss();

      // CHECK STOP LOSS FIRST (highest priority)
      if(gridProfit <= -currentStopLoss)
      {
         Print("STOP LOSS triggered: GridProfit=$", gridProfit,
               " | Dynamic SL=$", currentStopLoss,
               " | Day Profit Before=$", dayNetProfit);

         // Store balance BEFORE closing to calculate realized P/L later
         balanceBeforeClose = AccountInfoDouble(ACCOUNT_BALANCE);

         RequestCloseAll(true, currentStopLoss);
         Dashboard();
         return;
      }

      // CHECK TRAILING STOP (NO fixed profit target)
      // Uses dynamic trail step based on position count + minimum profit floor
      if(gridPeakProfit >= GridTrailStart)
      {
         double dynamicStep = GetDynamicTrailStep();
         double trailCloseLevel = GetTrailCloseLevel();  // Includes min profit floor

         if(gridProfit <= trailCloseLevel)
         {
            Print("TRAILING STOP triggered: Peak=$", gridPeakProfit,
                  " | Current=$", gridProfit,
                  " | Dynamic Step=$", dynamicStep,
                  " | Positions=", TotalOurPositions(),
                  " | Close Level=$", trailCloseLevel,
                  " | Min Floor=$", MinTrailProfit,
                  " | Day Profit Before=$", dayNetProfit);

            // Store balance BEFORE closing to calculate realized P/L later
            balanceBeforeClose = AccountInfoDouble(ACCOUNT_BALANCE);

            RequestCloseAll(false);
            Dashboard();
            return;
         }
         // In trailing mode, let profits run
      }
      // If trailing not yet active, just wait (no fixed profit target)

      // Manage grid (add positions if allowed)
      ManageGrid();

      Dashboard();
      return;
   }

   // STEP 2: No positions - check if we can open new trade
   if(totalPositions == 0)
   {
      // Check if we can open new trades
      if(CanOpenNewTrades() && AllowTrading())
      {
         OpenFirstTrade();
      }

      Dashboard();
      return;
   }

   Dashboard();
}
